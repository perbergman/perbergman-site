<?xml version="1.0" encoding="UTF-8"?>
<poetry>
  <about name="DharmaMist_1111" date="2015-03-24..2015-12-31" uri="">
    Per Bergman
  </about>
  <poems>
    <poem name="Greyhound/Good Morning Mr Buddy Morrow" id="greyhound-good-morning-mr-buddy-morrow-001" seq="001" date="2015-03-24" time="20:20" year="2015" index="1" xml:space="preserve">
      <stanza>
        <line caesura="1">So funny / looking out</line>
        <line caesura="1">Finding song / not my can of meat</line>
        <line caesura="1">Still / So cute</line>
        <line caesura="1">So lovely / So astute</line>
        <line caesura="1">So Absolute / ‘bout</line>
        <line caesura="1">Greyhound / Xsing</line>
        <line caesura="1">The Plains / Looking out</line>
        <line caesura="1">For each / and other</line>
      </stanza>
      <stanza>
        <line caesura="2">Greeyyy Hound/ Greeyhound / bring my baby home</line>
        <line caesura="1">Bring her home tonite / when she throws her arms around me</line>
        <line caesura="1">Let my baby ride / to keep me sane</line>
      </stanza>
      <stanza>
        <line caesura="1">Lookin’ in / so funny</line>
        <line caesura="1">Can of meat / So much honey</line>
        <line caesura="1">So Cute / Wild</line>
        <line caesura="1">So Absurd / So …</line>
        <line caesura="1">The Abstract Plains / Planes Xsing over</line>
        <line caesura="1">Where we / will live</line>
        <line>A perfect day yet to end</line>
      </stanza>
      <stanza>
        <line caesura="2">Lookin’ So Funny / Lookin’ So Out / Inside &amp;</line>
      </stanza>
    </poem>
    <poem name="in the Fog" id="in-the-fog-002" seq="002" date="2015-03-24" time="20:36" year="2015" index="2" xml:space="preserve">
      <stanza>
        <line>the train in the fog</line>
        <line>rolling past the red</line>
        <line>lights swaying</line>
        <line>Night Train</line>
        <line>Mystic, bebop, and Parker</line>
        <line>All at once, they go the distance</line>
        <line>From end to end</line>
      </stanza>
      <stanza>
        <line>Night Train</line>
        <line>The soft sound</line>
        <line>By the Fog, so sweet in darkness</line>
        <line>Parker, Col Train, Monk Sphere</line>
        <line>All together now</line>
      </stanza>
      <stanza>
        <line>Lights swinging &amp; The rail  &amp; Rattling wagons</line>
        <line>Rolling past the Rock, and all together</line>
        <line>Night Train</line>
        <line>In the Fog so smooth</line>
        <line>From end to this</line>
        <line>end</line>
      </stanza>
    </poem>
    <poem name="Believe Bitches!" id="believe-bitches-003" seq="003" date="2015-03-24" time="20:43" year="2015" index="3" xml:space="preserve">
      <stanza>
        <line caesura="1">Can’t get started – Man I can’t get started so rainy outside and the shoes are too wet I can’t get started, not today.  so walk then in your socks – Man get the coffee boilin’ the engine runnin’ the first light of Absolute Love, keeps the Water Out of Question  In the morning lights – all those cats lookin’ up hungry an’ so so grey meow, they say meow, they say, looking mean and hungry they mean it! anyway / I can’t get started as clouds fly by  buy me shoes – Man!</line>
      </stanza>
    </poem>
    <poem name="Rio, Rio, Rio" id="rio-rio-rio-004" seq="004" date="2015-03-24" time="20:50" year="2015" index="4" xml:space="preserve">
      <stanza>
        <line>I’ll Get By…</line>
        <line>When it is tough</line>
        <line>When it is light</line>
        <line>When it is dark</line>
        <line>When you are not there</line>
        <line>Out of Sight</line>
      </stanza>
      <stanza>
        <line>Nuits De Chine</line>
        <line>In the East</line>
      </stanza>
      <stanza>
        <line>The very thoughts</line>
        <line>About Love and it is</line>
        <line>There</line>
        <line>When it is dark</line>
        <line>When it is light</line>
        <line>When it is tough</line>
      </stanza>
      <stanza>
        <line>I’ll get by… and I will get by</line>
        <line>The dark night the star night the hidden night in daylight</line>
        <line>Fleeting dust in that alley</line>
      </stanza>
      <stanza>
        <line>Just you – I’ll close my eyes</line>
        <line>Out of Sight, Absolutely – Out of Sight</line>
        <line>The very Love and it is</line>
        <line>There</line>
        <line>In that Alley with hidden lights</line>
      </stanza>
      <stanza>
        <line>So then I think “I Got By: times like these”</line>
      </stanza>
    </poem>
    <poem name="Minty Oh Minty" id="minty-oh-minty-005" seq="005" date="2015-03-24" time="21:24" year="2015" index="5" xml:space="preserve">
      <stanza>
        <line>Oh, there he goes</line>
        <line>Minty, the Minty</line>
      </stanza>
      <stanza>
        <line>Freshly, from the printy’</line>
        <line>All over the place</line>
        <line>Not wastin’ his pace</line>
      </stanza>
      <stanza>
        <line>The day of this time is…</line>
        <line>Full of Love &amp; Time</line>
        <line>No, no</line>
      </stanza>
      <stanza>
        <line>Walking briskly</line>
        <line>Passed the bridge</line>
        <line>Open at such Fervor</line>
        <line>Trying to out</line>
        <line>his pace</line>
      </stanza>
      <stanza>
        <line>bring it on</line>
        <line>he say</line>
      </stanza>
      <stanza>
        <line caesura="1">roll on / roll on</line>
        <line>all the way home tonite</line>
        <line>where he goes</line>
      </stanza>
    </poem>
    <poem name="Død Kalm" id="d-d-kalm-006" seq="006" date="2015-03-27" time="21:57" year="2015" index="6" xml:space="preserve">
      <stanza>
        <line>So the waters are slowly fading into a rest</line>
        <line>Place for the last rites</line>
        <line>For the writhe</line>
        <line>The writing on the shattered pieces of wood is hard to decrypt</line>
        <line>As they got softer by the water erosion</line>
      </stanza>
      <stanza>
        <line>This is the Saga, made for you</line>
      </stanza>
      <stanza>
        <line>The foghorn from infinite distance barely makes itself heard</line>
        <line>As it has travelled though black holes, white holes, wormholes,</line>
        <line>Wormwood growing in the fields of Algeria back in the Fifties</line>
        <line>All the white houses, blue skies, smell of heat and dust</line>
      </stanza>
      <stanza>
        <line>Smoke of a pipe finding it is way</line>
        <line>Smoke of the water dripping on the pavement</line>
        <line>As the summer day is slowly fading into a rest</line>
      </stanza>
    </poem>
    <poem name="Africa" id="africa-007" seq="007" date="2015-03-27" time="22:18" year="2015" index="7" xml:space="preserve">
      <stanza>
        <line>Africa, rhythms</line>
        <line>Africa, cats</line>
        <line>River, Congo,</line>
        <line>Black Heart Darkness</line>
      </stanza>
      <stanza>
        <line>The Voodoo from the Western Lands</line>
        <line>Trippin’ in to empty our identities into</line>
      </stanza>
      <stanza>
        <line>Forgetfulness</line>
        <line>That dusty bowl with tumble weed collectors</line>
        <line>Tumblin’ down; the hill; sides with the weak</line>
      </stanza>
      <stanza>
        <line>Reaching a place without water yet another day</line>
        <line>Jornada del Muerto</line>
        <line>Sandy Dandy Dunes</line>
        <line>White cotton mirages miring reflexes from out spaced hymns</line>
      </stanza>
    </poem>
    <poem name="While" id="while-008" seq="008" date="2015-03-28" time="22:40" year="2015" index="8" xml:space="preserve">
      <stanza>
        <line>The Autumn leaves when they leave</line>
        <line>Exaktly, leave it at that</line>
      </stanza>
      <stanza>
        <line>while somewhere completely else</line>
        <line>black helicopters descent</line>
      </stanza>
      <stanza>
        <line>wondering which the last words</line>
        <line>will be spoken</line>
      </stanza>
      <stanza>
        <line>still,</line>
        <line>ness</line>
      </stanza>
      <stanza>
        <line>and breakin’ thru to the other side</line>
        <line>where the sun is wet</line>
        <line>and where the water bright</line>
      </stanza>
      <stanza>
        <line>long walks</line>
        <line>along</line>
        <line>side by side</line>
      </stanza>
      <stanza>
        <line>while somewhere completely else (or utterly not)</line>
        <line>white helicopters ascent</line>
      </stanza>
      <stanza>
        <line>while necessity requires</line>
        <line>wandering and speaking the maybe last words?</line>
      </stanza>
    </poem>
    <poem name="Raisin’" id="raisin-009" seq="009" date="2015-03-28" time="22:45" year="2015" index="9" xml:space="preserve">
      <stanza>
        <line>I wish it would fucking rain tonite</line>
        <line>So hell hot, so drastically hot</line>
        <line>Here</line>
        <line>Sunshine blue skies go away</line>
      </stanza>
      <stanza>
        <line>Please</line>
      </stanza>
      <stanza>
        <line>I wish it would rain on this</line>
        <line>Charade</line>
        <line>So badly, I would go outside, and kick some ass</line>
        <line>on this hot pavement</line>
      </stanza>
      <stanza>
        <line>melted lava sand in my shoes</line>
        <line>head aching of no water in sight for 100 years so far</line>
      </stanza>
      <stanza>
        <line>ain’t not the damn rain gods doomed thirsty too?</line>
        <line>ain’t the voodoo doll full of dry needles</line>
        <line>Or is this rainless day locked up full of gloom?</line>
      </stanza>
      <stanza>
        <line>Makin’ pancakes on the stove</line>
        <line>Rain, rain, rain</line>
        <line>Raisin’ Racing Rainy Rain</line>
      </stanza>
      <stanza>
        <line>Brain is out, the lava sand hardened all frozen waves in this land of hot hell ness, while the drying spectacle goes on for another century!</line>
      </stanza>
      <stanza>
        <line>Time never intended to be open-ended, right?</line>
      </stanza>
    </poem>
    <poem name="Prick Ly" id="prick-ly-010" seq="010" date="2015-03-28" time="22:58" year="2015" index="10" xml:space="preserve">
      <stanza>
        <line>far ways long away the prickly pear cactus grows silently,</line>
        <line>	with some hesitation</line>
      </stanza>
      <stanza>
        <line>in the periphery a shadow shows its silhouette,</line>
        <line>	 in the margin and outside of known thoughts</line>
      </stanza>
      <stanza>
        <line>footsteps anchored by the bridge,</line>
        <line>	shallow waters flushing free of the mindless person who forgot to close</line>
        <line>	time and insanity threw the key away</line>
        <line>	the bottom of the bottomless ocean keeps this secret hidden</line>
      </stanza>
      <stanza>
        <line>until the day of cactus blooming comes out in universe</line>
        <line>made of Love &amp; Tears &amp; Sand less Desert Storms &amp; Smokeless Chimneys &amp; Old car repair shops smelling stale black oil getting stuck on your shoes as you didn't really ever looked where you were going,</line>
        <line>as it goes on as usual business that is.</line>
      </stanza>
    </poem>
    <poem name="Well" id="well-011" seq="011" date="2015-03-28" time="11:11" year="2015" index="11" xml:space="preserve">
      <stanza>
        <line>Well,</line>
        <line>simmering above</line>
      </stanza>
      <stanza>
        <line>Some corn flakes gotten soggy by days in the mist</line>
        <line>Some animals less interested in that look the other way</line>
        <line>As the person of interest slowly walks the wrong way</line>
      </stanza>
      <stanza>
        <line caesura="1">Not realizing that the map might show the ways not taken/or not to take</line>
      </stanza>
      <stanza>
        <line>Well,</line>
        <line>That is all fine and dandy</line>
        <line>Said in a slowly old man’s voice</line>
      </stanza>
      <stanza>
        <line>Sitting in the grass children are playing with a tired Rottweiler</line>
        <line>Called Suzy</line>
        <line>But Suzy won’t play this rotten game as she found</line>
        <line>Some animals less interested</line>
        <line>In who thrown away those corn flakes</line>
        <line>Losing their flavor as well as aging in a less sincere way</line>
      </stanza>
      <stanza>
        <line>All watched gracefully from above, in that black one-eyed balloon.</line>
      </stanza>
    </poem>
    <poem name="Beat!" id="beat-012" seq="012" date="2015-03-29" time="00:00" year="2015" index="12" xml:space="preserve">
      <stanza>
        <line>want to make them one</line>
        <line>where is the end</line>
        <line>want to know when</line>
      </stanza>
      <stanza>
        <line>make them one</line>
        <line>so we are running</line>
        <line>against shadows of our self’s shadows</line>
      </stanza>
      <stanza>
        <line>make them one</line>
        <line>shadow and gray light</line>
      </stanza>
      <stanza>
        <line>the red dot in the tunnel</line>
        <line>make them one</line>
      </stanza>
      <stanza>
        <line>no one will come</line>
        <line>so that</line>
        <line>can be</line>
        <line>who is not be</line>
      </stanza>
      <stanza>
        <line>beat…</line>
      </stanza>
      <stanza>
        <line>so make them one</line>
        <line>else they wont come</line>
      </stanza>
      <stanza>
        <line>what a chic</line>
        <line>so there it will</line>
        <line>come when</line>
        <line>we go against</line>
      </stanza>
      <stanza>
        <line>the original</line>
        <line>source</line>
        <line>path way up</line>
        <line>past the last exit</line>
        <line>past the last entry</line>
      </stanza>
      <stanza>
        <line>make them one</line>
        <line>else they won’t come</line>
      </stanza>
      <stanza>
        <line>beat…</line>
      </stanza>
      <stanza>
        <line>storm drain flood</line>
        <line>tidal eternal flowers growing</line>
        <line>in that faint red light</line>
      </stanza>
      <stanza>
        <line>make them one</line>
        <line>else we go against</line>
      </stanza>
    </poem>
    <poem name="#66" id="66-013" seq="013" date="2015-03-29" time="00:20" year="2015" index="13" xml:space="preserve">
      <stanza>
        <line>the room was cool and dark</line>
        <line>oh so black</line>
      </stanza>
      <stanza>
        <line>shaking</line>
        <line>make a movement</line>
        <line>shock</line>
      </stanza>
      <stanza>
        <line>the room was cool and bright</line>
        <line>oh so bright</line>
      </stanza>
      <stanza>
        <line>wired</line>
        <line>make a sound</line>
        <line>shock</line>
      </stanza>
      <stanza>
        <line>the room was dark and bright</line>
        <line>oh stripes</line>
        <line>so many stripes</line>
      </stanza>
      <stanza>
        <line>knocking at the door</line>
        <line>don’t make a sound</line>
        <line>the bells are tingling, #66</line>
      </stanza>
      <stanza>
        <line>the room was not there</line>
        <line>not cool</line>
        <line>not bright</line>
        <line>not dark</line>
        <line>not white</line>
        <line> #66, never forget</line>
      </stanza>
    </poem>
    <poem name="Suona (after LA)" id="suona-after-la-014" seq="014" date="2015-04-23" time="21:42" year="2015" index="14" xml:space="preserve">
      <stanza>
        <line>Burroughs - how is the sound listening?</line>
        <line>Accepting adversity</line>
        <line>Adapting to conditions</line>
      </stanza>
      <stanza>
        <line>Basic breath Return</line>
        <line>Wholesome space</line>
        <line>Wholesome ground</line>
      </stanza>
      <stanza>
        <line>Loosen</line>
        <line>Lost</line>
        <line>Gone</line>
      </stanza>
      <stanza>
        <line>Thus colors vivid</line>
        <line>Trembling</line>
        <line>Octaves up into</line>
      </stanza>
      <stanza>
        <line>Cut down</line>
        <line>Cut Up</line>
        <line>Black and white flickering</line>
        <line>16 mm</line>
      </stanza>
      <stanza>
        <line>Await the space</line>
        <line>Filling up</line>
        <line>Disappearing in rapid succession</line>
      </stanza>
      <stanza>
        <line>Connected and not</line>
        <line>At the pivotal point choosing when there is no choice</line>
      </stanza>
    </poem>
    <poem name="Expanding Universe/Keep Going" id="expanding-universe-keep-going-015" seq="015" date="2015-04-23" time="22:00" year="2015" index="15" xml:space="preserve">
      <stanza>
        <line>Weird, as time goes my mind is expanding</line>
        <line>More space</line>
        <line>Fewer obstacles</line>
        <line>A bit lonely though, everybody busy</line>
        <line>It is like history is not</line>
        <line>Future is not</line>
        <line>Current feels weird too, unreal</line>
        <line>Like a Japanese forest, in the winter</line>
        <line>Jiki intensely connected without ego</line>
        <line>No questions asked, dualism has to die every moment</line>
        <line>Trinity – The Sound of Silence, and the expanding fireball in all ten directions.</line>
      </stanza>
      <stanza>
        <line>To not ‘have’ anything is the real freedom here, beyond the heat wave, colder than 0K.</line>
      </stanza>
      <stanza>
        <line>Beyond samsara, nirvana, the stream entered, the stream returned, beyond all – hosts and guests entering and leaving.</line>
      </stanza>
    </poem>
    <poem name="Fighters in the Rain" id="fighters-in-the-rain-016" seq="016" date="2015-04-24" time="11:26" year="2015" index="16" xml:space="preserve">
      <stanza>
        <line>All comes back</line>
        <line>To my old friends</line>
        <line>Sartre, Camus, Tzara</line>
      </stanza>
      <stanza>
        <line>All this fleeting dust coming and going</line>
        <line>Hopes, disappointment, the fine line between real and unreal</line>
        <line>Trying to, trying to</line>
      </stanza>
      <stanza>
        <line>The love and the Absolute Love</line>
        <line>The flowers, the colors, the waves</line>
        <line>All perfect, all</line>
      </stanza>
      <stanza>
        <line>Still that urge and sting</line>
        <line>ego biting its tail trying to make itself real</line>
        <line>mind in circles, flattening the grass before lying to down to sleep</line>
      </stanza>
      <stanza>
        <line>Looking at the ocean, waves coming back, forever and ever</line>
        <line>Stickiness of Objects</line>
        <line>Boulder up the mountain</line>
        <line>Toy Horse</line>
      </stanza>
      <stanza>
        <line>Playing chess with my old friends, bit nervous, but it is ok</line>
      </stanza>
    </poem>
    <poem name="Spheres in Spheres" id="spheres-in-spheres-017" seq="017" date="2015-04-24" time="19:00" year="2015" index="17" xml:space="preserve">
      <stanza>
        <line>We are like spheres sailing in space, intersecting, merging, passing…</line>
        <line>Not solid, but hollow, like those deep sea transparent creatures</line>
        <line>Flowing around in a sensual fashion</line>
      </stanza>
      <stanza>
        <line>The sphere can sometimes harden and get stiff, which is something easy to get used to</line>
        <line>but it is always, always possible to reach that softness again</line>
        <line>and let the light shine through</line>
        <line>semi-transparent, bit fuzzy</line>
      </stanza>
      <stanza>
        <line>this is not easy to experience but happens at times</line>
        <line>when you least expect it</line>
      </stanza>
      <stanza>
        <line>it is the hardness that puts obstacles in place</line>
        <line>but it erodes and turns in to an appearance or an apparition maybe?</line>
      </stanza>
    </poem>
    <poem name="EL ALMA Y EL CUERPO" id="el-alma-y-el-cuerpo-018" seq="018" date="2015-04-29" time="19:37" year="2015" index="18" xml:space="preserve">
      <stanza>
        <line>oh yeah</line>
        <line>all these rhythms</line>
        <line>and beats</line>
      </stanza>
      <stanza>
        <line>fuego</line>
        <line>för fasen</line>
        <line>ignition starts in ten seconds</line>
      </stanza>
      <stanza>
        <line>extreme purification</line>
        <line>peeling away</line>
        <line>the skin</line>
      </stanza>
      <stanza>
        <line>a path’s trajectory</line>
        <line>fuego</line>
        <line>going</line>
      </stanza>
      <stanza>
        <line>up in flames</line>
        <line>the old stuff</line>
        <line>that really was good for its time</line>
      </stanza>
      <stanza>
        <line>but who would understand?</line>
        <line>Soul and body</line>
        <line>On fire</line>
      </stanza>
    </poem>
    <poem name="State of Affairs" id="state-of-affairs-019" seq="019" date="2015-04-29" time="19:54" year="2015" index="19" xml:space="preserve">
      <stanza>
        <line>(a very crazy spiritual friend told me that she could see me go to Jamaica and expound the Dharma Mist instead of wasting cycles in front of the screen day in day out)</line>
      </stanza>
      <stanza>
        <line>(so here I am sitting wasting cycles in front of the screen again) repeat ad finitum</line>
      </stanza>
      <stanza>
        <line>#(but the ’I’ is slowly transmigrating during an intertial circular movement, through the initial nanosecond of fuel burning the primary entering Stage I)</line>
      </stanza>
      <stanza>
        <line>(so happy wholeheartedly wholesomely wholeisiticly)</line>
      </stanza>
      <stanza>
        <line>(past, present, future – where did you all go – here we go again)</line>
      </stanza>
      <stanza>
        <line>(recursive (and transitive) ininininvocation of the demon’s names)</line>
      </stanza>
      <stanza>
        <line>(the quality and characteristics of the spiral – yes - but is it going up or down?)</line>
      </stanza>
      <stanza>
        <line caesura="1">#(so the pressure compresses Li6/Li7 into fusion – Stage II - the eerie device from hell)</line>
      </stanza>
      <stanza>
        <line>(***maps, these ****maps…, blackbird stuck in the air)</line>
      </stanza>
      <stanza>
        <line>(beyond beyond language - evocation of Avalokiteśvara (अवलोकितेश्वर) )</line>
      </stanza>
      <stanza>
        <line>#(Stage III – all out – no return from here on)</line>
      </stanza>
    </poem>
    <poem name="Cravings" id="cravings-020" seq="020" date="2015-05-02" time="16:35" year="2015" index="20" xml:space="preserve">
      <stanza>
        <line>the cravings sought after</line>
        <line>the vacuum left behind</line>
      </stanza>
      <stanza>
        <line>where the dust is stirred up</line>
        <line>causing havoc and suffering</line>
      </stanza>
      <stanza>
        <line>why so easy to give in?</line>
        <line>the idling moving dust around</line>
        <line>no settlement</line>
        <line>no calm</line>
      </stanza>
      <stanza>
        <line>and, the dust follows along</line>
        <line>can call it dirt too</line>
      </stanza>
      <stanza>
        <line>new locations, same dust</line>
        <line>new relationships, same dust</line>
        <line>sensory</line>
        <line>perceptory</line>
        <line>cognitory</line>
      </stanza>
      <stanza>
        <line>when to wake up?</line>
        <line>Twelve chains</line>
      </stanza>
      <stanza>
        <line>Dust in the eyes makes it harder to see clear</line>
        <line>And clarity, purity are the opposite of dust</line>
        <line>So practice the Dharma only for the sake of the Dharma!</line>
      </stanza>
    </poem>
    <poem name="faith in Mind" id="faith-in-mind-021" seq="021" date="2015-05-02" time="21:16" year="2015" index="21" xml:space="preserve">
      <stanza>
        <line>so heavy, so heavy</line>
        <line>dark, void</line>
        <line>trapped under ice</line>
      </stanza>
      <stanza>
        <line>really experiencing samsara</line>
        <line>silence</line>
        <line>echoes</line>
      </stanza>
      <stanza>
        <line>valley with green leaves wet, windy</line>
        <line>smell of rain</line>
        <line>isolation, cabin with windows covered, the spider in a box</line>
      </stanza>
      <stanza>
        <line>hearing the sound of the stream flowing past</line>
        <line>throbbing pulse</line>
        <line>trying to find it</line>
      </stanza>
      <stanza>
        <line>entering the stream</line>
        <line>leaving the flow of the six dusts</line>
      </stanza>
    </poem>
    <poem name="Empty Cans" id="empty-cans-022" seq="022" date="2015-05-06" time="20:53" year="2015" index="22" xml:space="preserve">
      <stanza>
        <line>The high-pitched surges from the mind emitter</line>
        <line>splatters on the wall</line>
        <line>with a buzz</line>
        <line>as the guest and the host argue endlessly</line>
      </stanza>
      <stanza>
        <line>while the breeze turns silent after a long day</line>
      </stanza>
      <stanza>
        <line>when somewhere else...</line>
      </stanza>
      <stanza>
        <line>appears</line>
        <line>as mirages in the desert</line>
        <line>dunes moving</line>
        <line>the trash bins falling in the wind, empty and smelly</line>
        <line>the soiled wrapping paper</line>
        <line>where a sandwich was to be found</line>
      </stanza>
      <stanza>
        <line>that plastic scratchy sound</line>
        <line>the empty can rattling</line>
        <line>in the silent side street</line>
      </stanza>
      <stanza>
        <line>cracks showing their edges</line>
        <line>in the stark sunlight</line>
      </stanza>
      <stanza>
        <line>as reflections bounce</line>
        <line>of the wall</line>
      </stanza>
    </poem>
    <poem name="Rey" id="rey-023" seq="023" date="2015-05-06" time="21:27" year="2015" index="23" xml:space="preserve">
      <stanza>
        <line>so</line>
        <line>never stops</line>
      </stanza>
      <stanza>
        <line>the beat</line>
        <line>the sounds</line>
      </stanza>
      <stanza>
        <line>watery colors falling along the glass</line>
        <line>crushed stones</line>
        <line>under the rail</line>
      </stanza>
      <stanza>
        <line>glowing forrest fires in the Mojave desert</line>
        <line>driving I40</line>
      </stanza>
      <stanza>
        <line>so many miles</line>
        <line>of life passed</line>
      </stanza>
      <stanza>
        <line>so many hours</line>
        <line>of life passed</line>
      </stanza>
      <stanza>
        <line>nostalgic recollection before turning around the corner</line>
        <line>trying to let go</line>
        <line>some of it</line>
        <line>that was painful</line>
      </stanza>
      <stanza>
        <line>trying to keep</line>
        <line>some of it</line>
        <line>that wasn't</line>
      </stanza>
    </poem>
    <poem name="African Head Charge Recueillement" id="african-head-charge-recueillement-024" seq="024" date="2015-05-15" time="21:33" year="2015" index="24" xml:space="preserve">
      <stanza>
        <line>Jungle sounds</line>
        <line>hellish Green</line>
        <line>insects…</line>
      </stanza>
      <stanza>
        <line>The eerie river winding through</line>
        <line>past villages with people waving by</line>
      </stanza>
      <stanza>
        <line>the exotic Strangers</line>
        <line>getting further into Darkness</line>
      </stanza>
      <stanza>
        <line>in search of the true heart hidden</line>
        <line>deep in the forgotten Valleys</line>
        <line>the forgotten byways</line>
        <line>the forgotten paths</line>
      </stanza>
      <stanza>
        <line>once on maps</line>
        <line>that got moist and moldy</line>
        <line>thrown out</line>
        <line>lost</line>
      </stanza>
      <stanza>
        <line>the journey starts affecting</line>
        <line>no water no food</line>
        <line>hallucination</line>
        <line>desillusion</line>
        <line>no noitcerid anymore</line>
      </stanza>
      <stanza>
        <line>the dangerous animals hidden</line>
        <line>the weird sounds</line>
        <line>echoes</line>
        <line>blurred lines of vision</line>
        <line>ripples in the water</line>
        <line>mud gets thicker</line>
      </stanza>
      <stanza>
        <line>the borders between you and me and nature disappears</line>
        <line>the light reflected by the surface, blinding</line>
        <line>the smell of the moist jungle, intense</line>
      </stanza>
      <stanza>
        <line>the sight is getting weaker</line>
        <line>as it is getting darker</line>
        <line>as the sun quickly dissipates</line>
        <line>getting more quiet</line>
        <line>last piece of mind dropped</line>
        <line>last piece of body erased</line>
      </stanza>
      <stanza>
        <line>now entering the realm</line>
        <line>the otherness</line>
        <line>the stream</line>
        <line>the void</line>
        <line>where darkness is truth</line>
        <line>light is lie</line>
      </stanza>
      <stanza>
        <line>reaching the shore eventually</line>
        <line>putting the raft into the water</line>
        <line>all silent now</line>
      </stanza>
      <stanza>
        <line>in expectation</line>
        <line>in fear</line>
        <line>in curiosity</line>
      </stanza>
      <stanza>
        <line>can vaguely hear the paddles</line>
        <line>at a slow but steady pace</line>
        <line>water dripping</line>
        <line>with a peculiar echo</line>
      </stanza>
      <stanza>
        <line>not a soul</line>
        <line>not a spirit</line>
        <line>not an apparition</line>
      </stanza>
      <stanza>
        <line>this is the vast space beyond</line>
        <line>way beyond</line>
        <line>the jungle is thinning</line>
        <line>smell of fires</line>
        <line>drier land</line>
      </stanza>
      <stanza>
        <line>so with no map</line>
        <line>no recollection</line>
        <line>no recall</line>
        <line>no memory</line>
        <line>no traces of steps left</line>
        <line>no return</line>
      </stanza>
      <stanza>
        <line>where and what are you finally?</line>
      </stanza>
    </poem>
    <poem name="Early Bronze Age" id="early-bronze-age-025" seq="025" date="2015-05-15" time="22:34" year="2015" index="25" xml:space="preserve">
      <stanza>
        <line>something was there</line>
        <line>snow softly covering tracks of the white rabbit</line>
        <line>sound of a gate moaning in the wind</line>
      </stanza>
      <stanza>
        <line>could someone please step in and fix it?</line>
        <line>It is annoying as I’m trying to sleep</line>
        <line>this sound</line>
      </stanza>
      <stanza>
        <line>the flow of cold air escaping through the window frame gap</line>
        <line>It is annoying as I’m trying to sleep</line>
        <line>this cold</line>
      </stanza>
      <stanza>
        <line>the so hot fire previously</line>
        <line>winding down into ashes, its determined destiny</line>
        <line>spreading the cold</line>
        <line>overtaking the heat</line>
      </stanza>
      <stanza>
        <line>entering disturbed unruly sleep</line>
        <line>train</line>
        <line>It is annoying</line>
        <line>this sound</line>
      </stanza>
      <stanza>
        <line>the steam engine loud and steamy</line>
        <line>vibrating</line>
        <line>pulsating</line>
      </stanza>
      <stanza>
        <line>white smoke</line>
        <line>softly covering the tracks</line>
        <line>where the train passed</line>
      </stanza>
      <stanza>
        <line>into the eternal fog of cloud tunnels white out</line>
        <line>wheels slipping up the incline</line>
        <line>It is annoying as I am trying to sleep</line>
      </stanza>
      <stanza>
        <line>Soon the greyness of morning appears</line>
        <line>The snowfall ceased</line>
        <line>The gate is finally quiet</line>
      </stanza>
      <stanza>
        <line>But nowhere I can find trace of tracks</line>
        <line>Something was there?</line>
      </stanza>
    </poem>
    <poem name="What is Dada?" id="what-is-dada-026" seq="026" date="2015-05-15" time="23:19" year="2015" index="26" xml:space="preserve">
      <stanza>
        <line>Dada is the forgotten newspaper from yesterday left at the bench</line>
        <line>Dada is the mystery</line>
        <line>Dada is the thought that never came up</line>
        <line>It is the beat lost its rhythm</line>
        <line>Dada is the sunlight</line>
        <line>It is the love impossible</line>
        <line>Dada is the dog howling for no apparent reason</line>
        <line>It is the chance not taken</line>
        <line>Dada is the smoke of the pipe not yet lit</line>
      </stanza>
      <stanza>
        <line>Dada is the child dancing on the beach</line>
        <line>Not knowing yet</line>
        <line>Dada is not a toy horse, no way!</line>
        <line>Dada is neither creation nor destruction</line>
        <line>So it is not Shiva then?</line>
        <line>Dada is embracing anything that is made ready</line>
        <line>All of it</line>
        <line>Dada is the crab walking in the wet sand</line>
        <line>Dada doesn’t care about hi or lo</line>
      </stanza>
      <stanza>
        <line>Dada is like the dervish dancing in the street</line>
        <line>The butterfly flickering its wings, beautifully</line>
        <line>Dada is the happiness and lightness without any reason what.so.ever</line>
        <line>Licking its wounds</line>
        <line>Dada is vicious openness</line>
        <line>Staring Death in the face</line>
        <line>Dada is riding the wooden horse</line>
        <line>Talking back in a broken accent</line>
        <line>Dada is just wondrous</line>
      </stanza>
      <stanza>
        <line>That it is!</line>
      </stanza>
    </poem>
    <poem name="Throttle" id="throttle-027" seq="027" date="2015-05-16" time="22:36" year="2015" index="27" xml:space="preserve">
      <stanza>
        <line>grinding halt</line>
        <line>it just stopped</line>
        <line>everything just stopped</line>
      </stanza>
      <stanza>
        <line>like falling and freezing mid air</line>
        <line>clock between second and third</line>
        <line>rewinding all days</line>
      </stanza>
      <stanza>
        <line>all the surfaces created</line>
        <line>blown apart</line>
        <line>a soundless implosion</line>
      </stanza>
      <stanza>
        <line>all built</line>
        <line>all trashed</line>
        <line>blueprint is wrong</line>
      </stanza>
      <stanza>
        <line>surface as an addiction</line>
        <line>miscalculation of all</line>
        <line>throw the paper in the basket, try again</line>
      </stanza>
    </poem>
    <poem name="Sonnet#1" id="sonnet-1-028" seq="028" date="2015-05-17" time="09:11" year="2015" index="28" xml:space="preserve">
      <stanza>
        <line>Oh the endless scare the everlasting fear of loosing</line>
        <line>Early morning it comes as the first light seeping</line>
        <line>Behind the wall of sleep I can hide forgetting</line>
        <line>The grey heavy thoughts slowly like preying tigers sneaking</line>
      </stanza>
      <stanza>
        <line>Once we were the way it always should have been</line>
        <line>But time passes and gaps start to form without warning</line>
        <line>Cracks in the road slowly appearing from not before seen</line>
        <line>The loud parties the long nights now quiet just yawning</line>
      </stanza>
      <stanza>
        <line>But the thunderstorm and rainy fall blistering the green copper</line>
        <line>Grass wet soil darkened closing windows chairs moving</line>
        <line>That fresh scent spreading over land trees aligned proper</line>
        <line>Slowly clouds fade as the eternal sun again rays burning</line>
      </stanza>
      <stanza>
        <line>As the myriad of forms ever-changing never lasting long</line>
        <line>Is the cause of the curse never holding on very strong</line>
      </stanza>
    </poem>
    <poem name="Unedit" id="unedit-029" seq="029" date="2015-05-18" time="21:45" year="2015" index="29" xml:space="preserve">
      <stanza>
        <line>Unedit the grooves the patterns the constructions the concepts</line>
        <line>Decay die implode annihilate exterminate terminate eradicate</line>
        <line>Distrust the images the sounds the voices the closed hearts</line>
        <line>Disable the fuse the igniter the X Unit the dog buried</line>
        <line>Defuse the confused the righteous the known the not knowing</line>
      </stanza>
      <stanza>
        <line>Flow the darkness the light the specter the diamond the thunderbolt</line>
        <line>Unflow the dissipations of energy seeping to the eyes of death and rot</line>
        <line>The karmic roots of despair and unsettlements unpaid debts</line>
        <line>The primordial ground zero of senselessness devoid of nothingness</line>
        <line>Grind teeth against chains rusty by water from septic channels</line>
      </stanza>
      <stanza>
        <line>Speculate body mind division going astray into Hades and Hell and Horror</line>
        <line>Spew fire dragon fire occult drama spectacle and tombs</line>
        <line>Disengage the rabid system of word virus detection failures</line>
        <line>Separation is the chainsaw of Texas, diabolic and so natural for us</line>
        <line>Marbles rolling on the hardwood floor above driving into insanity</line>
      </stanza>
      <stanza>
        <line>The cat chasing shadows and laser beams covering vast areas of uncharted terror-tory</line>
        <line>Mismanage all resources plans thoughts order and executives</line>
        <line>Misfire friendly weapons hitting the wrong target, the nuclear device does not care much</line>
        <line>The Abyss is the Asylum the Refugee Camp the Base the Compound the Source.</line>
      </stanza>
    </poem>
    <poem name="Oh Milou Mon Ami" id="oh-milou-mon-ami-030" seq="030" date="2015-05-18" time="22:08" year="2015" index="30" xml:space="preserve">
      <stanza>
        <line>always keeping the spirits high</line>
        <line>finding the marrow the essence</line>
        <line>in each bone revealed</line>
      </stanza>
      <stanza>
        <line>all the beautiful whiteness ruffled by the wind</line>
        <line>those all-seeing pitch black eyes</line>
        <line>cats beware of this one</line>
      </stanza>
      <stanza>
        <line>riding the ocean</line>
        <line>flying the air</line>
        <line>walking the desert ground of Egypt</line>
      </stanza>
      <stanza>
        <line>scaring mummies golden crabs gorillas</line>
        <line>big psychedelic mushrooms roaming the island, the secret star</line>
        <line>flight 714 into the secret underground volcanic lands</line>
      </stanza>
      <stanza>
        <line>but,</line>
        <line>there is one slight issue</line>
        <line>the one about tiny spiders…</line>
      </stanza>
    </poem>
    <poem name="Winter" id="winter-031" seq="031" date="2015-05-19" time="21:00" year="2015" index="31" xml:space="preserve">
      <stanza>
        <line>The influx of the sound of broken springs, is dampening. Lights out now and time to go to bed, yet again. The cold draft runs over the wooden floor with its cracks.</line>
        <line>The wall paper screams forgetting! One day it is all good, most days it is not good at all. Where is this coming from, this winter blues?  Even reading some Japanese poems doesn't cheer me up.</line>
        <line>Not watching the movies, or reading a book, having dinner with a friend, nothing can soften this emotion.</line>
      </stanza>
      <stanza>
        <line>Oh, this blues. I was maybe expecting someone else to take me out of it as the skies getting darker, why doesn't she call?</line>
        <line>Why so dreary, hibernating deep down in the cave having dry crackers and weak tea.</line>
      </stanza>
      <stanza>
        <line>Oh, this blues, missing the African drums and the bright blue skies, the fresh smell.</line>
        <line>But, alas, not the time, not the time...</line>
      </stanza>
    </poem>
    <poem name="Sounds" id="sounds-032" seq="032" date="2015-05-19" time="23:00" year="2015" index="32" xml:space="preserve">
      <stanza>
        <line>Evening at Big Island, Buddhist bed and breakfast,  was hoping to get some sleep after a long trip, maybe the faint sound of the temple bells would be soothing</line>
      </stanza>
      <stanza>
        <line>BUT THEN:</line>
      </stanza>
      <stanza>
        <line>one million tree frogs making themselves heard at the same time in the jungle I would say: put your head behind a running jet engine, nothing in comparison to the damn frogs</line>
      </stanza>
      <stanza>
        <line>eventually it quiets down a bit until it is time for the five am morning sit now the faint sound of the temple bells is soothing</line>
      </stanza>
    </poem>
    <poem name="Wolf Hour" id="wolf-hour-033" seq="033" date="2015-05-21" time="16:36" year="2015" index="33" xml:space="preserve">
      <stanza>
        <line>Summer - a yellow breeze of gorgeous rays bouncing off the calm ocean surface, throwing small flashes of silver into your eyes.</line>
      </stanza>
      <stanza>
        <line>Summer - silently sipping sweet strawberry smoothie!</line>
      </stanza>
      <stanza>
        <line>The rhubarb with its bitter flavors evokes strong memories - sun setting, the swallows chirping and flying low, hunting flies, as the sky eventually turns darker blue, entering the Wolf Hour.</line>
      </stanza>
    </poem>
    <poem name="First take" id="first-take-034" seq="034" date="2015-05-21" time="18:04" year="2015" index="34" xml:space="preserve">
      <stanza>
        <line>rubber band flashing flights aeroplane corrugated big engines loudness metallic distant noises large fields endless limestone walls flat yellow flowers dried up water wells, the cows staring - friend or foe? tired after walking for a long time, water is out soon getting dark so lost, so alone and lonely out here and now the fog comes rolling in, moist and low visibility low altitude low dew point hear sounds of animals, Moose or Elk or worse? seeing shadows unclarity confusion grows should I stay or find my way back the mist horn in the distance (fog or mist - what gives?) it feels like there is no distance between internal and external confusions maybe the 'me' is gone, no border, no limit but normally 'we' can't perceive got into a mud field now, slow mud and not quick mud shoes pulled of, all wet and cold</line>
        <line caesura="1">fallen angel crawling trying to find fixed ground but there is none, nothing to grasp to hold on to to attach life and/or death are the same at this point</line>
      </stanza>
    </poem>
    <poem name="Autumn" id="autumn-035" seq="035" date="2015-05-21" time="20:34" year="2015" index="35" xml:space="preserve">
      <stanza>
        <line>fire,</line>
        <line>	tunnels of fire burning</line>
      </stanza>
      <stanza>
        <line>leaf fires,</line>
        <line>	intensive phosphorus glowing bright</line>
        <line>	red, yellow and orange</line>
      </stanza>
      <stanza>
        <line>lurking behind,</line>
        <line>	appears the contours of trees glistening</line>
      </stanza>
      <stanza>
        <line>cascades of fireworks,</line>
        <line>	imaginary smell of the grey powder smoke floating in the air</line>
      </stanza>
      <stanza>
        <line>remember,</line>
        <line>	that special sound driving on the carpet of leaf wetness</line>
        <line>	covering the road</line>
      </stanza>
      <stanza>
        <line>the time,</line>
        <line>	when your bike skidded</line>
        <line>	the intensive pain when you fell</line>
      </stanza>
    </poem>
    <poem name="snowy" id="snowy-036" seq="036" date="2015-05-28" time="17:13" year="2015" index="36" xml:space="preserve">
      <stanza>
        <line>it is falling</line>
        <line>	one, two, another one</line>
        <line>that fresh scent</line>
        <line>	snowflakes</line>
        <line>very silently putting themselves to place</line>
      </stanza>
      <stanza>
        <line>people behind lit windows</line>
        <line>fireplaces, smoke from chimneys</line>
      </stanza>
      <stanza>
        <line>the cold air presses against the face</line>
        <line>the breathing out forms a misty cloud</line>
        <line>that dissolves quickly</line>
      </stanza>
      <stanza>
        <line>the whitening landscape is very monochrome, darkening</line>
      </stanza>
      <stanza>
        <line>with a white rabbit running zig zag in the field, disappearing</line>
        <line>its prints will soon be erased,</line>
        <line>like it never existed</line>
      </stanza>
      <stanza>
        <line>the black raven sitting in a tree, watching</line>
        <line>someone trying to make a snowball</line>
        <line>but gives up as the snow is too dry now</line>
      </stanza>
      <stanza>
        <line>			it is a spooky feeling,</line>
        <line>			when the first snow comes</line>
      </stanza>
    </poem>
    <poem name="Ambivalence" id="ambivalence-037" seq="037" date="2015-05-30" time="17:41" year="2015" index="37" xml:space="preserve">
      <stanza>
        <line>oh so sweet, oh so sour</line>
        <line>what is it gonna be?</line>
      </stanza>
      <stanza>
        <line>sweet child of mine?</line>
        <line>grumpy old man with a grudge, hitting his dog?</line>
      </stanza>
      <stanza>
        <line>walking on the beach,</line>
        <line>	being a Stranger</line>
        <line>	looking for something</line>
      </stanza>
      <stanza>
        <line>finally getting to the end of the road</line>
        <line>where this thing is</line>
      </stanza>
      <stanza>
        <line>the Ambivalent Fruitly Mango :-)</line>
      </stanza>
    </poem>
    <poem name="Addison Abeba" id="addison-abeba-038" seq="038" date="2015-06-04" time="20:12" year="2015" index="38" xml:space="preserve">
      <stanza>
        <line>evenings slow</line>
        <line>by the fire flies</line>
        <line>the rhythm bouncing</line>
        <line>sentimental</line>
        <line>nostalgic</line>
        <line>better days</line>
      </stanza>
      <stanza>
        <line>that longing</line>
        <line>to a time that didn’t really exist</line>
      </stanza>
      <stanza>
        <line>to a place now gone</line>
      </stanza>
      <stanza>
        <line>to persons long forgotten, disappeared</line>
        <line>walked away and out of sight as the road curved</line>
      </stanza>
      <stanza>
        <line>change happened</line>
        <line>trying to relive but never the same</line>
        <line>as that time</line>
      </stanza>
      <stanza>
        <line>kind of pain and joy at the same time</line>
      </stanza>
      <stanza>
        <line>the fire is consumed</line>
        <line>glow fading</line>
        <line>time to go home</line>
      </stanza>
    </poem>
    <poem name="really" id="really-039" seq="039" date="2015-06-07" time="22:09" year="2015" index="39" xml:space="preserve">
      <stanza>
        <line>happy with images of wormwood fields and ruins in Algeria</line>
        <line>sand &amp; water &amp; the sun &amp; the moon</line>
        <line>&amp; the wind</line>
      </stanza>
      <stanza>
        <line>solar eclipse and the total silence of it</line>
        <line>the craters on the moon, seems so lonely there</line>
        <line>the waterfall splashing</line>
      </stanza>
      <stanza>
        <line>tropical rains hitting hard</line>
        <line>before I can close the windows</line>
        <line>trying to dry clothes in this climate?</line>
      </stanza>
      <stanza>
        <line>big and small bugs – you have to get over it</line>
        <line>lotus flowers in the pond, and frogs</line>
        <line>but no worn out images of Japanese Cherry trees this time, ain’t that lucky…</line>
        <line>lapis lazuli blues-ness in all ten directions</line>
      </stanza>
      <stanza>
        <line>we have vision but obscured</line>
        <line>the white magnetic fields</line>
        <line>by fallen down twitching and sparkling power lines</line>
      </stanza>
      <stanza>
        <line>these Ancient lands with the smell of wormwood and moss on the stones</line>
      </stanza>
    </poem>
    <poem name="afterlife" id="afterlife-040" seq="040" date="2015-06-10" time="21:53" year="2015" index="40" xml:space="preserve">
      <stanza>
        <line>oh,</line>
        <line>the cosmic high ground</line>
        <line>the karmic disaster fields</line>
      </stanza>
      <stanza>
        <line>the optional</line>
        <line>the forgotten</line>
      </stanza>
      <stanza>
        <line>oh,</line>
        <line>the primordial light source</line>
        <line>before</line>
      </stanza>
      <stanza>
        <line>gap between impulses</line>
        <line>spark plugs oily basterds</line>
      </stanza>
      <stanza>
        <line>oh,</line>
        <line>Western waste lands</line>
        <line>polluted mind control bugs</line>
      </stanza>
      <stanza>
        <line>incense burning slowly orange</line>
        <line>lamp silently illuminating</line>
      </stanza>
      <stanza>
        <line>oh,</line>
        <line>supra carnal grounds</line>
        <line>bones left embedded</line>
      </stanza>
      <stanza>
        <line>sow the seed fall failed soil</line>
        <line>you get the bitter fruit nipping you like a nasty hound!</line>
      </stanza>
    </poem>
    <poem name="dulce" id="dulce-041" seq="041" date="2015-06-10" time="20:30" year="2015" index="41" xml:space="preserve">
      <stanza>
        <line>deluded existential ultra negative Alien body hunters are coming for you</line>
      </stanza>
      <stanza>
        <line caesura="1">sailboats with sails ripped in the time/space continuum escapes detection in the Triangle</line>
      </stanza>
      <stanza>
        <line>tea leaves flushing down the sewer pipes of Paris</line>
      </stanza>
      <stanza>
        <line>quantum daemons hastily paddles across the stream chasing that unknowable cat, Cheshire?</line>
      </stanza>
      <stanza>
        <line>death squads of Pinochet’s ghost knocking at the door</line>
        <line>trying to peep hole</line>
      </stanza>
      <stanza>
        <line>distorted satanic verses tumbling past Joseph K’s grave</line>
        <line>and the compass needle moves like a crazy person on LSD</line>
      </stanza>
      <stanza>
        <line>drum beats in ecstatic jungle fever fueled frantically</line>
        <line>mountainous terrain hard to pass, rugged, where is the Dulce Base?</line>
      </stanza>
      <stanza>
        <line>undercover terminators knocking at hollow tombs, emptied mummies</line>
        <line>#23 is the one</line>
      </stanza>
      <stanza>
        <line>hyper encrypted loneliness behind closed circuits of eternal tritium boosters</line>
      </stanza>
      <stanza>
        <line>ultra wavelength stealth de-icers humming as the temperature goes down to 0K, still subsonic mystic movements</line>
      </stanza>
      <stanza>
        <line>exceptions to the virus are hard to come by,</line>
        <line>still, the beat goes on</line>
      </stanza>
    </poem>
    <poem name="heat" id="heat-042" seq="042" date="2015-06-10" time="21:38" year="2015" index="42" xml:space="preserve">
      <stanza>
        <line>let the heat</line>
        <line>flow</line>
      </stanza>
      <stanza>
        <line>so it goes</line>
      </stanza>
      <stanza>
        <line>white lucid light</line>
        <line>sobering</line>
      </stanza>
      <stanza>
        <line>the autumn</line>
        <line>leaves</line>
        <line>something on the ground</line>
        <line>less</line>
        <line>something above the ground</line>
      </stanza>
      <stanza>
        <line>here it goes</line>
      </stanza>
      <stanza>
        <line>the summer</line>
        <line>heat</line>
        <line>let it flow</line>
        <line>yellow river</line>
        <line>run</line>
      </stanza>
      <stanza>
        <line>there it goes</line>
      </stanza>
      <stanza>
        <line>fall time</line>
        <line>fell down</line>
        <line>sprouting green</line>
        <line>frogs squeakin’</line>
        <line>the guys tweakin’</line>
      </stanza>
      <stanza>
        <line>goes so it does…</line>
      </stanza>
      <stanza>
        <line>winter</line>
        <line>tracks in snow</line>
        <line>wet clothes</line>
        <line>drippin’ and smellin’</line>
        <line>on the floo’</line>
      </stanza>
    </poem>
    <poem name="Hell Bomb" id="hell-bomb-043" seq="043" date="2015-06-10" time="22:15" year="2015" index="43" xml:space="preserve">
      <stanza>
        <line>lightning fast implosion</line>
        <line>urchin kick-start</line>
        <line>supercritical primary stage fission fuel core burn out</line>
        <line>plastic plasma mirrored surface</line>
        <line>radiation pressure</line>
        <line>lithium6 secondary stage</line>
        <line>transmigrating isotopes fusion yield</line>
        <line>stage three shell radiation boost</line>
      </stanza>
      <stanza>
        <line>artificial death light sphere</line>
        <line>second sun exploding</line>
        <line>polaroid inferno blinding eyes meltdown</line>
        <line>miles per millisecond fireball</line>
      </stanza>
      <stanza>
        <line>extreme waves of violent lava storms</line>
        <line>immense air pressure</line>
        <line>secondary ground shock</line>
      </stanza>
      <stanza>
        <line>houses vanish paper like</line>
        <line>oxygen gone shelters melt</line>
        <line>human shadows left irradiated flesh mud like</line>
        <line>unresolvable pain</line>
      </stanza>
      <stanza>
        <line>thermal hell cloud rising fast</line>
        <line>stratospheric fallout</line>
        <line>heavy ground contamination</line>
      </stanza>
      <stanza>
        <line>life failure</line>
        <line>earth failure</line>
        <line>game over</line>
      </stanza>
    </poem>
    <poem name="prison" id="prison-044" seq="044" date="2015-06-10" time="20:54" year="2015" index="44" xml:space="preserve">
      <stanza>
        <line>Dogen:</line>
        <line>“The thing is, if there is the slightest gap, sky and earth are ripped apart. If you give rise to even a flicker of like and dislike, you lose your mind in delusion”.</line>
      </stanza>
      <stanza>
        <line>I think</line>
        <line>thus I suffer, tremendously</line>
      </stanza>
      <stanza>
        <line>think there is a sky</line>
        <line>there is earth</line>
        <line>above</line>
        <line>different.</line>
      </stanza>
      <stanza>
        <line>think there are humans</line>
        <line>that care</line>
        <line>but the gap is there</line>
      </stanza>
      <stanza>
        <line>think there is compassion</line>
        <line>that soothes</line>
        <line>my gaping empty eyes</line>
      </stanza>
      <stanza>
        <line>so the ripping</line>
        <line>the skin bleeds</line>
        <line>pain</line>
        <line>the soul bleeds</line>
        <line>pain</line>
        <line>the mind bleeds</line>
        <line>pain</line>
      </stanza>
      <stanza>
        <line>flickering hope inside somewhere?</line>
        <line>letting the delusional dogs out, who did?</line>
        <line>sky and earth unified</line>
        <line>mind is evaporated, skin is healed, gap is gone</line>
      </stanza>
    </poem>
    <poem name="lost spiders" id="lost-spiders-045" seq="045" date="2015-06-11" time="22:04" year="2015" index="45" xml:space="preserve">
      <stanza>
        <line>writing pain and writing devastation</line>
        <line>before writing love</line>
        <line>and new construction</line>
      </stanza>
      <stanza>
        <line>did I make a fool of myself now?</line>
        <line>said too much</line>
        <line>too strong</line>
        <line>too fast</line>
      </stanza>
      <stanza>
        <line>something broke,</line>
        <line>or is it ok?</line>
      </stanza>
      <stanza>
        <line>from within all bubbles up</line>
        <line>the filter can’t hold it</line>
      </stanza>
      <stanza>
        <line>the floor squeaks</line>
        <line>as I am</line>
        <line>pacing back and forth</line>
        <line>thinking</line>
      </stanza>
      <stanza>
        <line>the moist spread extreme suffering</line>
      </stanza>
      <stanza>
        <line>under the surface</line>
        <line>fear is crawling</line>
      </stanza>
      <stanza>
        <line>spiders coming from all directions</line>
        <line>weaving weaving the web</line>
      </stanza>
      <stanza>
        <line>covering my lost mind</line>
      </stanza>
    </poem>
    <poem name="operator mistake" id="operator-mistake-046" seq="046" date="2015-06-13" time="23:03" year="2015" index="46" xml:space="preserve">
      <stanza>
        <line>fail</line>
        <line>down</line>
        <line>utterly</line>
      </stanza>
      <stanza>
        <line>dead</line>
        <line>halt</line>
        <line>now</line>
      </stanza>
      <stanza>
        <line>map</line>
        <line>without</line>
        <line>lines</line>
      </stanza>
      <stanza>
        <line>road</line>
        <line>without</line>
        <line>exit</line>
      </stanza>
      <stanza>
        <line>lake</line>
        <line>without</line>
        <line>water</line>
      </stanza>
      <stanza>
        <line>in the depth</line>
        <line>without</line>
        <line>oxygen</line>
      </stanza>
      <stanza>
        <line>mind</line>
        <line>without</line>
        <line>rest</line>
      </stanza>
      <stanza>
        <line>deathless and lifeless</line>
        <line>colorless odor of gas seeping in</line>
        <line>sleepless voodoo doctor</line>
      </stanza>
      <stanza>
        <line>falling</line>
        <line>down</line>
        <line>utterly</line>
      </stanza>
      <stanza>
        <line>tired</line>
        <line>of retrying</line>
        <line>or rebooting</line>
      </stanza>
      <stanza>
        <line>never finding traction</line>
        <line>of recycling same matter</line>
      </stanza>
    </poem>
    <poem name="Red light" id="red-light-047" seq="047" date="2015-06-13" time="00:04" year="2015" index="47" xml:space="preserve">
      <stanza>
        <line>Night in bed</line>
        <line>Dark room</line>
        <line>All the sensory</line>
        <line>Sadness creeps into me</line>
      </stanza>
      <stanza>
        <line>Connect so far</line>
        <line>Touch not close</line>
        <line>Smell hair long ago</line>
        <line>Brutal honesty</line>
      </stanza>
      <stanza>
        <line>red light in the dark room</line>
        <line>Scares away</line>
        <line>Into the corners</line>
        <line>Dusty piles dead bugs</line>
      </stanza>
      <stanza>
        <line>Swimming in darker water</line>
        <line>Dreaming can't see anywhere</line>
        <line>Drags me down</line>
        <line>Deep down into ever sleep</line>
      </stanza>
    </poem>
    <poem name="Night mode" id="night-mode-048" seq="048" date="2015-06-13" time="00:13" year="2015" index="48" xml:space="preserve">
      <stanza>
        <line>Everybody left</line>
        <line>Stomach aches</line>
        <line>Tears</line>
      </stanza>
      <stanza>
        <line>The fight</line>
        <line>The arguments</line>
        <line>The heat</line>
      </stanza>
      <stanza>
        <line>In the night swept in by silent covers</line>
        <line>I lie thinking and hurting</line>
        <line>The old alarm clock ticking</line>
      </stanza>
      <stanza>
        <line>A day gone by</line>
        <line>Into the horizon never to be seen like that</line>
      </stanza>
    </poem>
    <poem name="Amazon Brain" id="amazon-brain-049" seq="049" date="2015-06-13" time="22:25" year="2015" index="49" xml:space="preserve">
      <stanza>
        <line>A flower falls, even though we love it; and a weed grows, even though we do not love it.</line>
      </stanza>
      <stanza>
        <line>just silent in head today</line>
        <line>not much going on</line>
        <line>bit disturbance</line>
        <line>but not too much</line>
      </stanza>
      <stanza>
        <line>quite few things rattling</line>
        <line>some loose screws</line>
        <line>the brain has to undergo surgery</line>
        <line>by the mind mechanic</line>
      </stanza>
      <stanza>
        <line>need to replace some parts</line>
        <line>can’t find the right ones</line>
        <line>duct tape won’t fix it</line>
        <line>so it won’t work as well as before</line>
      </stanza>
      <stanza>
        <line>maybe Amazon has some good deals</line>
        <line>for refurbished brain parts?</line>
      </stanza>
    </poem>
    <poem name="Pulse beating" id="pulse-beating-050" seq="050" date="2015-06-15" time="22:50" year="2015" index="50" xml:space="preserve">
      <stanza>
        <line>Very loud in empty room</line>
        <line>Can hear thoughts</line>
      </stanza>
      <stanza>
        <line>As life signal faints</line>
        <line>The monitor flat lines</line>
      </stanza>
      <stanza>
        <line>Thin red lines</line>
        <line>Moving towards you</line>
        <line>In accelerating tempo</line>
        <line>Can't allow touch</line>
      </stanza>
      <stanza>
        <line>Enter the space between</line>
        <line>Life and death</line>
      </stanza>
      <stanza>
        <line>A stream of green water</line>
        <line>Odd beings here</line>
        <line>A smell of sulphur</line>
        <line>Trees without leaves</line>
      </stanza>
      <stanza>
        <line>Swamp beings gurgle</line>
        <line>Moving towards you</line>
      </stanza>
      <stanza>
        <line>Hell country</line>
      </stanza>
    </poem>
    <poem name="travel fever" id="travel-fever-051" seq="051" date="2015-06-17" time="11:26" year="2015" index="51" xml:space="preserve">
      <stanza>
        <line>still, after all these years</line>
        <line>travel fever</line>
        <line>childish anticipation</line>
        <line>slight anxiety</line>
        <line>closing the door</line>
        <line>forgetting all the things inside</line>
        <line>just some luggage</line>
        <line>and myself</line>
        <line>all the hassle at the airport</line>
        <line>doesn’t matter</line>
        <line>part of it</line>
        <line>travel is to die a bit and to be reborn</line>
        <line>finally arriving</line>
        <line>freshness, lightness, adventure, happiness, love</line>
      </stanza>
    </poem>
    <poem name="Gucci" id="gucci-052" seq="052" date="2015-06-19" time="19:19" year="2015" index="52" xml:space="preserve">
      <stanza>
        <line>my dear Gucci</line>
        <line>days have past, ashes still dormant</line>
      </stanza>
      <stanza>
        <line>passed through the Bardo of 49 days</line>
        <line>arising into a new form</line>
      </stanza>
      <stanza>
        <line>turning the page</line>
        <line>long ride over unknown waters</line>
      </stanza>
      <stanza>
        <line>death scary thought</line>
        <line>cycle of birth and death</line>
        <line>is hard to break</line>
      </stanza>
      <stanza>
        <line>that is the way we all will walk</line>
        <line>but until then I miss you dearly, my friend!</line>
      </stanza>
    </poem>
    <poem name="e·qua·nim·i·ty" id="e-qua-nim-i-ty-053" seq="053" date="2015-06-25" time="18:50" year="2015" index="53" xml:space="preserve">
      <stanza>
        <line>the supreme</line>
      </stanza>
      <stanza>
        <line>release all attachments</line>
        <line>release all births</line>
        <line>release all deaths</line>
      </stanza>
      <stanza>
        <line>light darkness all gone</line>
      </stanza>
      <stanza>
        <line>fully open</line>
        <line>without obstruction</line>
        <line>still relative logic applies on Earth</line>
      </stanza>
      <stanza>
        <line>bullets just pass through</line>
        <line>still not hiding or running or arguing</line>
        <line>still here</line>
      </stanza>
      <stanza>
        <line>the paradox,</line>
        <line>the pivotal point where it flips</line>
      </stanza>
    </poem>
    <poem name="all these" id="all-these-054" seq="054" date="2015-06-26" time="18:27" year="2015" index="54" xml:space="preserve">
      <stanza>
        <line>oscillations</line>
      </stanza>
      <stanza>
        <line>as the reggae beat pumps</line>
        <line>makes me happy and calm</line>
      </stanza>
      <stanza>
        <line>it is in tune with something</line>
        <line>soft, serene, and magical</line>
        <line>backbeat interferes with linearity</line>
      </stanza>
      <stanza>
        <line>maybe…</line>
        <line> a lion is hiding under my bed</line>
        <line>maybe…</line>
        <line> the king of kings just disappeared round the corner</line>
        <line>maybe…</line>
        <line> illusions</line>
        <line>maybe…</line>
        <line> another realm, as real as this one?</line>
      </stanza>
      <stanza>
        <line>there are certainly spirits immersed in the beat</line>
      </stanza>
    </poem>
    <poem name="in sync" id="in-sync-055" seq="055" date="2015-06-26" time="18:42" year="2015" index="55" xml:space="preserve">
      <stanza>
        <line>be exactly in the flow of time</line>
      </stanza>
      <stanza>
        <line>not before</line>
        <line>not after</line>
      </stanza>
      <stanza>
        <line>time-being</line>
        <line>being-time</line>
      </stanza>
      <stanza>
        <line>us arise at the same time in light</line>
        <line>us annihilate at the same time in darkness</line>
      </stanza>
      <stanza>
        <line>constant flux</line>
        <line>no resting point</line>
        <line>but no connection either - disjoint</line>
      </stanza>
      <stanza>
        <line>all senses mix</line>
        <line>all logic dissolves</line>
        <line>three armed eight headed beings are just like that</line>
        <line>walking at the bottom of the ocean waving the arms above the water</line>
      </stanza>
      <stanza>
        <line>this text is already history, too late, and of no use</line>
      </stanza>
    </poem>
    <poem name="State of Jah" id="state-of-jah-056" seq="056" date="2015-06-26" time="17:47" year="2015" index="56" xml:space="preserve">
      <stanza>
        <line>*The happiness you feel when you get something you have always wanted typically lasts no longer than three days*</line>
      </stanza>
      <stanza>
        <line>after all strong waves</line>
        <line>blasting</line>
        <line>rushing</line>
        <line>crushing</line>
      </stanza>
      <stanza>
        <line>water becomes calmer</line>
        <line>less agitated</line>
        <line>but not yet Død Kalm</line>
      </stanza>
      <stanza>
        <line>a new phase</line>
        <line>a sense of beautiful and serene sadness,</line>
        <line>  sadness in a light hearted way</line>
      </stanza>
      <stanza>
        <line>first a crisp picture of an auspicious mountain range</line>
        <line>innards vague, getting clearer by time</line>
      </stanza>
      <stanza>
        <line>a jigsaw puzzle - white swans on a blue lake - but without a picture to compare with</line>
      </stanza>
      <stanza>
        <line>System Solar by itself</line>
      </stanza>
      <stanza>
        <line>this progression has its own life</line>
        <line>its own transformation</line>
        <line>just watch</line>
      </stanza>
      <stanza>
        <line>but to float in the groundless intersection of the uncertain and the absurd, between dream and reality,</line>
        <line>requires a certain ability</line>
      </stanza>
      <stanza>
        <line>this is why my name is传耐</line>
      </stanza>
    </poem>
    <poem name="on one hand" id="on-one-hand-057" seq="057" date="2015-06-26" time="18:56" year="2015" index="57" xml:space="preserve">
      <stanza>
        <line>expectations about how things should be and progress</line>
      </stanza>
      <stanza>
        <line>induction theorem</line>
        <line>inference machine</line>
        <line>the Almighty deduction detective</line>
        <line>experience &amp; opinions</line>
      </stanza>
      <stanza>
        <line>still,</line>
        <line>can’t capture the bliss</line>
        <line>can’t capture the disaster</line>
      </stanza>
      <stanza>
        <line>both,</line>
        <line>coming</line>
        <line>for you</line>
      </stanza>
      <stanza>
        <line>like…</line>
        <line>how the sudden white flash of thermonuclear detonation</line>
      </stanza>
      <stanza>
        <line caesura="1">/</line>
        <line>1. supercritical primary stage fission fuel core burn out</line>
        <line>2. plastic plasma mirrored surface</line>
        <line>3. radiation pressure</line>
        <line>4. lithium six seven secondary stage</line>
        <line>5. transmigrating isotopes fusion yield</line>
        <line>6. artificial death light sphere</line>
        <line>7. polaroid inferno blinding eyes meltdown</line>
        <line caesura="1">/</line>
      </stanza>
      <stanza>
        <line>overtakes all imagination</line>
        <line>of power</line>
        <line>and destruction</line>
      </stanza>
      <stanza>
        <line>the two headed being, being</line>
        <line>AMBIVALENCE, oscillating</line>
      </stanza>
      <stanza>
        <line>trying to fixate but not possible</line>
        <line>just a construct, a narrative</line>
        <line>from ashes to ashes</line>
      </stanza>
      <stanza>
        <line>all these ghosts imagined</line>
        <line>are coming for you, coming to get ya’</line>
      </stanza>
      <stanza>
        <line>and there is nowhere to hide</line>
        <line>so what do you want to do now?</line>
      </stanza>
    </poem>
    <poem name="celestial being" id="celestial-being-058" seq="058" date="2015-07-09" time="16:21" year="2015" index="58" xml:space="preserve">
      <stanza>
        <line>called celestial being the other day</line>
        <line>in a certain way that is uncommon</line>
      </stanza>
      <stanza>
        <line>seldom feel appreciated in being the human</line>
        <line>maybe took a too narrow view</line>
        <line>looking down</line>
      </stanza>
      <stanza>
        <line>like to feel real powers some day</line>
        <line>as other people see them</line>
      </stanza>
      <stanza>
        <line>fears and tears exist in the humans</line>
        <line>reuse and recycle requires a realm change</line>
        <line>step out of all known and enter the</line>
        <line>celestial (for lack of better words) mind storms</line>
      </stanza>
      <stanza>
        <line>instead of seeing only word play,</line>
        <line>time to step up and destroy your self</line>
      </stanza>
    </poem>
    <poem name="rest area" id="rest-area-059" seq="059" date="2015-07-09" time="18:31" year="2015" index="59" xml:space="preserve">
      <stanza>
        <line>on the road</line>
        <line>late,</line>
        <line>so very silent</line>
        <line>summer breeze</line>
      </stanza>
      <stanza>
        <line>the corn fields</line>
        <line>the park like settings</line>
        <line>smell of wet grass</line>
        <line>she is putting the towels to dry</line>
      </stanza>
      <stanza>
        <line>playing at the playground</line>
        <line>revolving drum</line>
        <line>going too fast</line>
      </stanza>
      <stanza>
        <line>life on the road</line>
        <line>have this golden moments</line>
        <line>never to be forgotten…</line>
      </stanza>
    </poem>
    <poem name="rest area 51" id="rest-area-51-060" seq="060" date="2015-07-11" time="21:10" year="2015" index="60" xml:space="preserve">
      <stanza>
        <line>in the air</line>
        <line>early,</line>
        <line>so very sonic dry</line>
        <line>space breeze</line>
      </stanza>
      <stanza>
        <line>landing fields</line>
        <line>blue light markings</line>
        <line>smell of kerosene</line>
        <line>hanging aliens to dry</line>
      </stanza>
      <stanza>
        <line>playing by Groom Lake</line>
        <line>revolving hangar doors</line>
        <line>keys thrown away so fast</line>
      </stanza>
      <stanza>
        <line>live abductions</line>
        <line>have this silver moments</line>
        <line>always to be forgotten…</line>
      </stanza>
      <stanza>
        <line>on the road</line>
        <line>in the air</line>
        <line>late,</line>
        <line>early,</line>
        <line>so very silent</line>
        <line>so very sonic dry</line>
        <line>summer breeze</line>
        <line>space breeze</line>
      </stanza>
      <stanza>
        <line>the corn fields</line>
        <line>landing fields</line>
        <line>the park like settings</line>
        <line>blue light markings</line>
        <line>smell of wet grass</line>
        <line>smell of kerosene</line>
        <line>she is putting the towels to dry</line>
        <line>hanging aliens to dry</line>
      </stanza>
      <stanza>
        <line>playing at the playground</line>
        <line>playing by Groom Lake</line>
        <line>revolving drum</line>
        <line>revolving hangar doors</line>
        <line>going too fast</line>
        <line>keys thrown away so fast</line>
      </stanza>
      <stanza>
        <line>life on the road</line>
        <line>live abductions</line>
        <line>have this golden moments</line>
        <line>have this silver moments</line>
        <line>never to be forgotten…</line>
        <line>always to be forgotten…</line>
      </stanza>
    </poem>
    <poem name="my very dear" id="my-very-dear-061" seq="061" date="2015-07-12" time="19:49" year="2015" index="61" xml:space="preserve">
      <stanza>
        <line>space princess</line>
        <line>celestial empress</line>
        <line>supra elevated wisdom realm</line>
      </stanza>
      <stanza>
        <line>beyond words and images</line>
        <line>beyond function</line>
        <line>in essence</line>
      </stanza>
      <stanza>
        <line>non-dualist existential magnetic attraction</line>
        <line>core coil vibrating</line>
        <line>love and all love</line>
      </stanza>
      <stanza>
        <line>all perfection infinite eternal timeless</line>
        <line>essence of emptiness</line>
        <line>impermanent resolution</line>
      </stanza>
      <stanza>
        <line>terminate these thoughts for ever and ever</line>
        <line>as love is forever and ever</line>
      </stanza>
    </poem>
    <poem name="plateau" id="plateau-062" seq="062" date="2015-07-12" time="20:56" year="2015" index="62" xml:space="preserve">
      <stanza>
        <line>all the pain and struggling</line>
        <line>finally getting somewhere</line>
        <line>I thought</line>
      </stanza>
      <stanza>
        <line>but the suffering comes after reaching the plateau</line>
        <line>not during the climb</line>
      </stanza>
      <stanza>
        <line>all pictures in my head, assumptions, about her</line>
        <line>things experienced, giving hope</line>
      </stanza>
      <stanza>
        <line>looking for signs</line>
        <line>but very unclear in the mist of things</line>
      </stanza>
      <stanza>
        <line>all very unclear</line>
        <line>maybe I am completely climbing the wrong mountain, in the wrong world, at the wrong time?</line>
      </stanza>
    </poem>
    <poem name="Tristan" id="tristan-063" seq="063" date="2015-07-12" time="23:47" year="2015" index="63" xml:space="preserve">
      <stanza>
        <line>Tristan Tzara, The Greatest Dadaist, lives in my bathroom sometimes.</line>
        <line>I am his incarnation, and we share toothbrush.</line>
        <line>He often takes a bath using an orange floating device.</line>
        <line>It doesn’t match his black clothes that well.</line>
      </stanza>
      <stanza>
        <line>But he is laughing it off, saying that’s life at its best!</line>
        <line>He spends the days writing poetry, shaving and drying my towel.</line>
        <line>Seldom does he go out, too sunny for his white skin, but it would help to dry his clothes a bit.</line>
      </stanza>
      <stanza>
        <line>He likes to eat ribs, but me being a vegetarian causes some issues, of significance.</line>
        <line>So Tristan is quite thin at this point, complains a lot.</line>
        <line>It can be quite crowded in my little bathroom too, privacy issues. It is still his workplace. Employees must wash their hands before going back to work.</line>
      </stanza>
      <stanza>
        <line>So, his paper gets moist as he doesn’t know what a computer is, at his age.</line>
        <line>I offered him my sofa, but he feels it is too much space; he needs to be confined a little, to create.</line>
      </stanza>
      <stanza>
        <line>But at times he disappears during the night, never figured out where he is going.</line>
        <line>He brings flowers back, to put under my pillow, as I pretend to sleep heavily.</line>
        <line>I kind of hope he always will be here, or maybe we will switch places?</line>
      </stanza>
    </poem>
    <poem name="out of memory" id="out-of-memory-064" seq="064" date="2015-07-13" time="08:53" year="2015" index="64" xml:space="preserve">
      <stanza>
        <line>this morning I ran out of memory</line>
        <line>didn’t remember to buy yesterday, or was it the day before?</line>
      </stanza>
      <stanza>
        <line>I usually go with the cheap stuff</line>
        <line>but it gets clogged with bad thoughts and images</line>
        <line>so fills up quicker</line>
      </stanza>
      <stanza>
        <line>also, that memory is a bit slow, which can be a nuisance and source of frustration</line>
        <line>things like remembering my name and SSN</line>
      </stanza>
      <stanza>
        <line>I know (do I) that there are new cool memories out there one can buy, but poor basterds like me can’t afford them</line>
      </stanza>
      <stanza>
        <line>Some even come with a demo version, memories of some celebrity like Ernest Hemingway. But wouldn’t that be just a long dark gap?</line>
      </stanza>
    </poem>
    <poem name="ghosts" id="ghosts-065" seq="065" date="2015-07-13" time="12:28" year="2015" index="65" xml:space="preserve">
      <stanza>
        <line>pain from</line>
        <line>	not knowing,</line>
        <line>	doubting,</line>
        <line>	the uncertainty</line>
        <line>her intentions?</line>
      </stanza>
      <stanza>
        <line>a sordine</line>
        <line>muted microphone</line>
        <line>no voice can be heard</line>
      </stanza>
      <stanza>
        <line>stir up ghastly hungry ghost daemons inside, eating the smell of well-being</line>
      </stanza>
      <stanza>
        <line>meeting her</line>
        <line>	blue skies</line>
        <line>	sunny</line>
        <line>	clear water</line>
        <line>	calm</line>
      </stanza>
      <stanza>
        <line>calming ghosts,</line>
        <line>but before sunset they awake again, angry ghosts!</line>
      </stanza>
      <stanza>
        <line>somewhere in the essential Tao there is a glimpse of the sun behind the clouds and steep mountainside</line>
      </stanza>
      <stanza>
        <line>Maybe Shambhala does exist for us persistent and sometimes tired Warriors?</line>
      </stanza>
    </poem>
    <poem name="ghosts: N Remix" id="ghosts-n-remix-066" seq="066" date="2015-07-13" time="15:05" year="2015" index="66" xml:space="preserve">
      <stanza>
        <line>no pain from</line>
        <line>	not knowing,</line>
        <line>	doubting,</line>
        <line>	the uncertainty</line>
        <line>her intentions are always Pure Love, as mine are</line>
      </stanza>
      <stanza>
        <line>a sordine</line>
        <line>muted microphone</line>
        <line>in the perfect silence that is implicit</line>
      </stanza>
      <stanza>
        <line>stirred up ghastly hungry ghost daemons inside, eating the smell of well-being,</line>
        <line>are friends helping in their own Love as they are you and me</line>
      </stanza>
      <stanza>
        <line>meeting her</line>
        <line>	blue skies</line>
        <line>	sunny</line>
        <line>	clear water</line>
        <line>	calm</line>
        <line>is a moment of bliss, not connected to anything before or after,</line>
        <line>as time itself is you and me,</line>
        <line>all the forms are coming from nothing, going to nothing</line>
      </stanza>
      <stanza>
        <line>before sunset the ghosts awake again,</line>
        <line>but harmless as my fear is overcome and the ‘I’ dissolved forever</line>
      </stanza>
      <stanza>
        <line>the essential Love is the glimpse of the sun behind the clouds and steep mountainside</line>
      </stanza>
      <stanza>
        <line>And there is nothing else in this Perfection</line>
      </stanza>
    </poem>
    <poem name="lion time" id="lion-time-067" seq="067" date="2015-07-13" time="19:02" year="2015" index="67" xml:space="preserve">
      <stanza>
        <line>the lion is sleeping afternoon wise</line>
        <line>Clock is moving very slowly away from it</line>
        <line>so scared of waking him up</line>
      </stanza>
      <stanza>
        <line>don’t want him to catch Time</line>
        <line>then all hell will certainly break loose</line>
      </stanza>
      <stanza>
        <line>all the hyenas, lionesses, and giraffes</line>
        <line>will get super angry</line>
        <line>where did Time go?</line>
      </stanza>
      <stanza>
        <line>well, they really don't care too much about it</line>
        <line>but we humans do</line>
        <line>trying to catch Time as it runs</line>
        <line>hiding in our phones and computers, even old church towers</line>
      </stanza>
      <stanza>
        <line>Time is seeping in through the walls and hermetic containers</line>
        <line>You can see it only when the moon is full and night sky is clear</line>
        <line>And then only a weak hint and outline of it.</line>
      </stanza>
      <stanza>
        <line>If you are really still, you might hear its breath,</line>
        <line>but then you are too close because he is already Watching you!</line>
      </stanza>
    </poem>
    <poem name="mind against machine" id="mind-against-machine-068" seq="068" date="2015-07-15" time="19:36" year="2015" index="68" xml:space="preserve">
      <stanza>
        <line>I see more of flickering and flashing creating these hollow figures we believe in</line>
        <line>I see my ego self flickering and flashing creating this hollow mind I believe in</line>
        <line>I see the totality flickering and flashing creating this hollow world I believe in</line>
      </stanza>
      <stanza>
        <line>Yours Hollowness,</line>
        <line>When am ‘I’ allowed to stop following mind streams?</line>
      </stanza>
      <stanza>
        <line>Today is a quiet today, not much movement, kind of neutral in its essence</line>
        <line>Not plus</line>
        <line>Not minus</line>
        <line>But not zero</line>
      </stanza>
      <stanza>
        <line>As day goes to night</line>
        <line>The other being arises</line>
        <line>The one losing track of time and control</line>
      </stanza>
      <stanza>
        <line>An odd bliss though</line>
        <line>A quiet joy</line>
      </stanza>
      <stanza>
        <line>Serene and otherworldly mind and time loss</line>
        <line>Starting to realize other realms as time stops going by</line>
      </stanza>
      <stanza>
        <line>Cool focus and awareness</line>
        <line>Joy comes by writing effortlessly and without any pressure</line>
        <line>As day goes to night</line>
      </stanza>
      <stanza>
        <line>Amazing as this other time replaces our time; it has its own life and rhythm</line>
        <line>So joy and bliss comes with that entering of the gate-less gate</line>
        <line>Finding the piece of gold</line>
      </stanza>
      <stanza>
        <line>The host and guest are both gone as light and darkness disappear, forever and ever</line>
        <line caesura="1">The Being and/or non-Being effortless unity and annihilation</line>
        <line caesura="1">Language barriers are broken; this vision is beyond language and/or non-language</line>
        <line caesura="1">Beyond description and/or non-description</line>
        <line>Beyond the idea of ideas, even past the Dao</line>
      </stanza>
      <stanza>
        <line>So now real tears appears…</line>
        <line>Tears of traveling</line>
        <line>Tears of finding home, zero base</line>
        <line>Tears of realizing that nothing moves</line>
        <line>Tears of insisting on not giving up these mind streams, but laughing at them</line>
      </stanza>
      <stanza>
        <line>The softness of existential awareness and water rings from the stone thrown in.</line>
        <line>The softness of just doing and letting do.</line>
        <line>The softness of just sitting, as the eternal centuries of masters have done without whining.</line>
      </stanza>
      <stanza>
        <line>The tears and softness of throwing out the soul and dead meat</line>
        <line>The wind of Earth, the wind of Sun, the wind of water</line>
        <line>The fire of passionless windless change</line>
        <line>The space of where the gate should have been</line>
      </stanza>
      <stanza>
        <line>The magnetic fields get weaker</line>
        <line>The laws start to loose effect</line>
      </stanza>
      <stanza>
        <line>Are we all in this illusion of descriptions?</line>
        <line>Are we all insane and ignorant?</line>
        <line>Are we all seeking validation?</line>
        <line>Are we all seeking fear avoidance death avoidance?</line>
      </stanza>
      <stanza>
        <line>All ten directions go awry</line>
        <line>Now close to breaking the code</line>
        <line>The code that is not really there</line>
      </stanza>
      <stanza>
        <line>All is gone</line>
        <line>The is gone</line>
        <line>Fear is gone</line>
        <line>Is is gone</line>
        <line>Gone is gone</line>
      </stanza>
    </poem>
    <poem name="basic" id="basic-069" seq="069" date="2015-07-15" time="22:15" year="2015" index="69" xml:space="preserve">
      <stanza>
        <line>morning temple bell</line>
        <line>fluid fog</line>
      </stanza>
      <stanza>
        <line>black robes</line>
        <line>waking early</line>
      </stanza>
      <stanza>
        <line>incense</line>
        <line>taking position</line>
      </stanza>
      <stanza>
        <line>in silence to silence</line>
        <line>sitting</line>
        <line>just</line>
      </stanza>
      <stanza>
        <line>tiny bell without anticipation</line>
        <line>sound of cloth</line>
      </stanza>
      <stanza>
        <line>sun rays are walking</line>
        <line>but is there any movement?</line>
      </stanza>
    </poem>
    <poem name="polarization" id="polarization-070" seq="070" date="2015-07-16" time="21:15" year="2015" index="70" xml:space="preserve">
      <stanza>
        <line>a message came a morning – all faded into blackest black</line>
        <line>a spear thrown into my heart</line>
        <line>bleeding to death on the floor</line>
      </stanza>
      <stanza>
        <line>this woman is so different from all before</line>
        <line>my mind started to spin awful stories</line>
        <line>this is the End</line>
      </stanza>
      <stanza>
        <line>day in zoombiefied daze</line>
        <line>inmate on death row having the last meal, slowly, slowly</line>
      </stanza>
      <stanza>
        <line>in the evening she sends a message</line>
        <line>she is going to call</line>
        <line>soon…</line>
      </stanza>
      <stanza>
        <line>eternal wait…</line>
      </stanza>
      <stanza>
        <line>then it becomes so clear</line>
        <line>that I was completely wrong</line>
      </stanza>
      <stanza>
        <line>the sun shines a bit,</line>
        <line>even in the darkest depth of the most moonless night</line>
      </stanza>
    </poem>
    <poem name="is bath water" id="is-bath-water-071" seq="071" date="2015-07-16" time="21:34" year="2015" index="71" xml:space="preserve">
      <stanza>
        <line>the grey bath water</line>
        <line>with the yellow duck</line>
        <line>holes in its head</line>
      </stanza>
      <stanza>
        <line>is fleeing the scene through the almost dry runoff arroyo</line>
      </stanza>
      <stanza>
        <line>never seen so many</line>
        <line>green crocodiles</line>
      </stanza>
      <stanza>
        <line>a celestial lemon beagle carefully</line>
        <line>watching</line>
      </stanza>
      <stanza>
        <line>over</line>
        <line>the Earth and its poor beings</line>
      </stanza>
      <stanza>
        <line>tail in suspense</line>
      </stanza>
    </poem>
    <poem name="tonite" id="tonite-072" seq="072" date="2015-07-17" time="21:47" year="2015" index="72" xml:space="preserve">
      <stanza>
        <line>lightness day</line>
        <line>fading into the dark</line>
        <line>softly</line>
      </stanza>
      <stanza>
        <line>day mind is turning off</line>
        <line>going into rest</line>
      </stanza>
      <stanza>
        <line>another mind</line>
        <line>awakes</line>
        <line>for the night</line>
      </stanza>
      <stanza>
        <line>dreams</line>
        <line>sleep</line>
        <line>.</line>
      </stanza>
    </poem>
    <poem name="void" id="void-073" seq="073" date="2015-07-17" time="21:56" year="2015" index="73" xml:space="preserve">
      <stanza>
        <line>mind and body empty vessels</line>
        <line>as time enters the final stage of the day</line>
        <line>the cycle goes back</line>
      </stanza>
      <stanza>
        <line>the illusion of forward</line>
        <line>singularity – one point</line>
        <line>no progression</line>
      </stanza>
      <stanza>
        <line>it is really the feeling of birth and death</line>
        <line>we create ornaments to escape this realization</line>
        <line>all these worries and thoughts filling the vessels</line>
      </stanza>
      <stanza>
        <line>the fear of being outside</line>
        <line>the circle</line>
        <line>out in the wilderness</line>
      </stanza>
      <stanza>
        <line>with no frames of reference</line>
        <line>only a star map</line>
        <line>the desert</line>
      </stanza>
      <stanza>
        <line>still</line>
        <line>traces of nostalgia</line>
        <line>how it was</line>
        <line>how it might be</line>
        <line>how it didn’t become</line>
      </stanza>
      <stanza>
        <line>problem is to break something that is not even there</line>
        <line>problem is to always recreating the unwholesomeness</line>
        <line>just by laziness</line>
      </stanza>
      <stanza>
        <line>“Pen Draig of the quill fire burns upon white sheets o plaited crystal golden flight in violet night a turquoise sheen”</line>
        <line role="turn">- Sabell K Gabriel</line>
      </stanza>
    </poem>
    <poem name="5150 Mental case" id="5150-mental-case-074" seq="074" date="2015-07-20" time="20:32" year="2015" index="74" xml:space="preserve">
      <stanza>
        <line>sometimes one can just be tired</line>
        <line>tired but feeling 5150</line>
      </stanza>
      <stanza>
        <line>all thoughts tiring</line>
        <line>body is tired</line>
        <line>weather is tired</line>
      </stanza>
      <stanza>
        <line>but nothing is really, really that wrong</line>
        <line>there is an internal smile knowing this</line>
      </stanza>
      <stanza>
        <line>all the pull from all directions</line>
        <line>all the push from all directions</line>
      </stanza>
      <stanza>
        <line>just tired</line>
        <line>without anything bothering</line>
      </stanza>
      <stanza>
        <line>throw an African Head Charge on it!</line>
      </stanza>
    </poem>
    <poem name="You make my toes stretch and curl catlike" id="you-make-my-toes-stretch-and-curl-catlik-075" seq="075" date="2015-07-21" time="21:34" year="2015" index="75" xml:space="preserve">
      <stanza>
        <line>I see some leaves there</line>
        <line>at the bottom</line>
        <line>of my cup</line>
        <line>translucent?</line>
      </stanza>
      <stanza>
        <line>winds of passions</line>
        <line>of all kinds</line>
        <line>sometimes go in the same direction at the same time</line>
      </stanza>
      <stanza>
        <line>just joy and bliss</line>
        <line>when this happens</line>
      </stanza>
      <stanza>
        <line>knowing that it changes maybe tomorrow again</line>
        <line>but have been witnessed</line>
        <line>and will show up again</line>
      </stanza>
      <stanza>
        <line>knowing suffering is ultimate</line>
        <line>but joy and bliss have their place in impermanence</line>
      </stanza>
      <stanza>
        <line>Valley of The Heavenly Kings</line>
        <line>Valley of Death &amp; Alive</line>
      </stanza>
      <stanza>
        <line caesura="2">/Your magnetism breathes through the moonlit trees. Edie Brickell/</line>
      </stanza>
    </poem>
    <poem name="cairo" id="cairo-076" seq="076" date="2015-08-08" time="8:18" year="2015" index="76" xml:space="preserve">
      <stanza>
        <line>this is love</line>
        <line>a good love it is</line>
        <line>absolutely a good love</line>
      </stanza>
      <stanza>
        <line>as it does not leave</line>
        <line>or shrink</line>
      </stanza>
      <stanza>
        <line>trembling at times</line>
        <line>heart &amp; beats &amp; warming &amp; easy and light &amp; magnetic</line>
      </stanza>
      <stanza>
        <line>your uniqueness &amp; clarity &amp; beauty &amp; wisdom</line>
        <line>dreaminess, timelessness</line>
        <line>inner smile &amp; outer</line>
      </stanza>
      <stanza>
        <line>other things lose their intensity</line>
        <line>in this amazement</line>
      </stanza>
      <stanza>
        <line>weaving magic together</line>
        <line>storm drain flood</line>
        <line>tidal eternal flowers growing</line>
        <line>in that deep red</line>
      </stanza>
      <stanza>
        <line>make them one</line>
      </stanza>
      <stanza>
        <line>(Response: beautiful (heart icon)words everflowing from your river of mind magic)</line>
      </stanza>
      <stanza>
        <line>Response (19:27):</line>
      </stanza>
      <stanza>
        <line>my salty skin</line>
        <line>quite possibly dissolves you</line>
        <line>making seen the core</line>
        <line caesura="1">of your soul/essence</line>
        <line>held in my palm</line>
        <line>and slowly cradled</line>
        <line>slight squeeze</line>
        <line>and you</line>
        <line>are all mine </line>
      </stanza>
      <stanza>
        <line>Number plate ‘SAB…’.</line>
        <line>Movie music ‘Explosions in the Sky’ (Manglehorn).</line>
      </stanza>
    </poem>
    <poem name="Deep Red" id="deep-red-077" seq="077" date="2015-08-03" time="16:25" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>'those karmic seeds eventually lead to a very beautiful place'</line>
        <line>'like yesterday'</line>
        <line>'no hesitation'</line>
        <line>'no fear'</line>
        <line>'all needed is there, awoken from hibernation'</line>
        <line>'deep blue deep green'</line>
        <line>'only deep red'</line>
        <line>...</line>
      </stanza>
    </poem>
    <poem name="Q Filter" id="q-filter-078" seq="078" date="2015-08-03" time="20:26" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>polarising</line>
        <line>filter removes sparkles</line>
      </stanza>
      <stanza>
        <line>opens the ocean surface</line>
        <line>to secrets</line>
      </stanza>
      <stanza>
        <line>that should have been buried?</line>
        <line>Q clearance</line>
      </stanza>
      <stanza>
        <line>they knock at you door</line>
        <line>asking</line>
        <line>polygraph type questions</line>
      </stanza>
      <stanza>
        <line>need to know</line>
        <line>basis</line>
      </stanza>
      <stanza>
        <line>trap streets on maps</line>
        <line>elevators stopping between floors</line>
      </stanza>
      <stanza>
        <line>sun glasses, always on</line>
      </stanza>
      <stanza>
        <line>waiting game</line>
        <line>surveillance state</line>
        <line>of mind</line>
      </stanza>
      <stanza>
        <line>looking behind your back</line>
      </stanza>
    </poem>
    <poem name="crx" id="crx-079" seq="079" date="2015-08-03" time="20:53" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>crx</line>
        <line>reversed</line>
      </stanza>
      <stanza>
        <line>beach</line>
        <line>down below</line>
        <line>the edge</line>
      </stanza>
      <stanza>
        <line>sun &amp; sand &amp; water &amp; wind &amp; space</line>
      </stanza>
      <stanza>
        <line>spicy sub &amp; watered coconut</line>
        <line>all cookies still alive at this point</line>
      </stanza>
      <stanza>
        <line>closeness</line>
        <line>softness velvet silk</line>
        <line>timeless</line>
        <line>intimate</line>
        <line>unique outside space-time disc-ontinuum</line>
      </stanza>
    </poem>
    <poem name="white castle" id="white-castle-080" seq="080" date="2015-08-04" time="21:33" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>moving slowly</line>
        <line>as the horizon</line>
        <line>settles</line>
      </stanza>
      <stanza>
        <line>flicker of lights behind moving tent veils</line>
        <line>fireplace can be grasped, reluctantly</line>
      </stanza>
      <stanza>
        <line>as we lie awake in the dark</line>
      </stanza>
      <stanza>
        <line>low voices</line>
        <line>whispering</line>
        <line>tea is prepared</line>
      </stanza>
      <stanza>
        <line>all these impressions</line>
        <line>fades</line>
      </stanza>
      <stanza>
        <line>as we lie awake in the dark</line>
      </stanza>
      <stanza>
        <line>in the vast space of the mighty desert</line>
        <line>the sand grains stuck in your hair</line>
        <line>carefully brushed</line>
        <line>away</line>
      </stanza>
      <stanza>
        <line>as we lie awake in the dark</line>
      </stanza>
      <stanza>
        <line>entering the gate-less gates</line>
        <line>of white sand castles</line>
        <line>icy waters</line>
        <line>and mountains suddenly appear in the distance</line>
      </stanza>
      <stanza>
        <line>last lights reflected in your eyes</line>
        <line>as we fade away in the warmth of the breeze</line>
      </stanza>
    </poem>
    <poem name="dark room" id="dark-room-081" seq="081" date="2015-08-05" time="18:37" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>very late evening</line>
        <line>wind is howling outside</line>
      </stanza>
      <stanza>
        <line>going into the Dark Room</line>
        <line>develop the roll of film I found in the camera</line>
        <line>left at a rest area in Nebraska</line>
      </stanza>
      <stanza>
        <line>odd with analog film nowadays</line>
        <line>but the dusty equipment is hardy, works</line>
      </stanza>
      <stanza>
        <line>kodak tri-x, classic</line>
        <line>there are nine frames taken</line>
      </stanza>
      <stanza>
        <line>1. winter scenery</line>
        <line>a woman lies in the snow</line>
        <line>a ski resort?</line>
        <line>bit overexposed</line>
        <line>noonish</line>
        <line>she has a serious gaze, not happy, not sad, determined</line>
        <line>some people further away</line>
        <line>not a good composition</line>
      </stanza>
      <stanza>
        <line>2. later, same place</line>
        <line>a man sitting with empty beer bottles</line>
        <line>indoors</line>
        <line>very sad,</line>
        <line>tired eyes</line>
        <line>shadows, late afternoon</line>
        <line>picture is artistic though</line>
        <line>good composition</line>
        <line>shadow play</line>
        <line>no grains, even with this film</line>
        <line>Looking closely I see a reflection in the window</line>
        <line>vague contours, the woman?</line>
      </stanza>
      <stanza>
        <line>3. car</line>
        <line>a car, covered with snow, can't see the plates</line>
        <line>older Ford</line>
        <line>seems to be packed and loaded</line>
        <line>ready to go</line>
        <line>evening time</line>
      </stanza>
      <stanza>
        <line>4. balcony</line>
        <line>the woman again, and her friend, maybe sister?</line>
        <line>laughing</line>
        <line>happy</line>
        <line>no worries</line>
        <line>need a bit more light to make it perfect</line>
        <line>but ok, still</line>
        <line>drinks on the table</line>
        <line>Cosmopolitan?</line>
        <line>can see the old Ford parked below, street lamps</line>
        <line>this is a better photographer, clearly</line>
      </stanza>
      <stanza>
        <line>5. pretty mountains</line>
        <line>classic landscape</line>
        <line>sunny</line>
        <line>blue sky</line>
        <line>snowy mountain</line>
        <line>can feel the crisp air</line>
        <line>a village in the distance, French flags? hard to say</line>
        <line>maybe the same photographer as #2. The woman? Who knows.</line>
        <line>it is early morning, not many out</line>
      </stanza>
      <stanza>
        <line>6. accidental</line>
        <line>picture by mistake, blurry</line>
        <line>rest room floor?</line>
        <line>very white</line>
        <line>drunken feeling</line>
      </stanza>
      <stanza>
        <line>7. the sad man again</line>
        <line>in profile, left side</line>
        <line>I see he has a wedding band</line>
        <line>holding his bottle in the left hand</line>
        <line>very rich picture, highlights and deep shadows</line>
        <line>sad that he looks so sad though</line>
        <line>Going back to #4, no rings visible?</line>
        <line>Break-up?</line>
      </stanza>
      <stanza>
        <line>8. snowballs</line>
        <line>the two women, playful</line>
        <line>one just got hit by a snowball</line>
        <line>rosy face</line>
        <line>both are quite attractive</line>
        <line>lots of white here</line>
      </stanza>
      <stanza>
        <line>9. finally</line>
        <line>a picture with people actually skiing</line>
        <line>none of our dear friends visible</line>
      </stanza>
    </poem>
    <poem name="chamber" id="chamber-082" seq="082" date="2015-08-05" time="21:12" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>running running running</line>
        <line>in a pitch dark room</line>
        <line>voices echoing</line>
        <line>chamber</line>
      </stanza>
      <stanza>
        <line>don't dare to stop</line>
        <line>feel the presence</line>
        <line>of Something</line>
      </stanza>
      <stanza>
        <line>Black Sun can't see it</line>
        <line>Black Sun can't feel it</line>
      </stanza>
      <stanza>
        <line>things rolling around</line>
        <line>falling falling falling</line>
      </stanza>
      <stanza>
        <line>feel the draft of air</line>
        <line>but from where?</line>
      </stanza>
      <stanza>
        <line>water rising</line>
        <line>floating with it</line>
        <line>getting cold</line>
      </stanza>
      <stanza>
        <line>Black Sun can't see it</line>
        <line>Black Sun can't feel it</line>
      </stanza>
      <stanza>
        <line>closing my eyes</line>
        <line>will I see away?</line>
      </stanza>
    </poem>
    <poem name="green eyes" id="green-eyes-083" seq="083" date="2015-08-05" time="21:47" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>so</line>
        <line>beautiful</line>
        <line>shimmering</line>
      </stanza>
      <stanza>
        <line>so</line>
        <line>sparkling</line>
        <line>playful</line>
      </stanza>
      <stanza>
        <line>so</line>
        <line>curious</line>
        <line>calm</line>
      </stanza>
      <stanza>
        <line>so</line>
        <line>deeply</line>
        <line>intensive</line>
      </stanza>
      <stanza>
        <line>and</line>
        <line>gorgeous</line>
      </stanza>
    </poem>
    <poem name="mind box" id="mind-box-084" seq="084" date="2015-08-06" time="19:27" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>mind box</line>
      </stanza>
      <stanza>
        <line>hyper freedom</line>
        <line>where no lines are drawn</line>
      </stanza>
      <stanza>
        <line>enter the stream mirror with no reflection</line>
        <line>the moon not visible in water</line>
        <line>sensory abort</line>
      </stanza>
      <stanza>
        <line>extreme pressure breakdown</line>
        <line>nuclear forces</line>
      </stanza>
      <stanza>
        <line>subsonic movements under water</line>
        <line>green colors abundant</line>
      </stanza>
      <stanza>
        <line>eerie sounds behind a door</line>
        <line>a key welded</line>
        <line>can't turn it</line>
      </stanza>
    </poem>
    <poem name="washed" id="washed-085" seq="085" date="2015-08-07" time="19:04" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>tiny sand bank in the river</line>
        <line>lying down, we found shade below the trees</line>
        <line>but sun rays slip through when tree tops move around</line>
        <line>eyes closed for a bit, blink, blink</line>
      </stanza>
      <stanza>
        <line>that effect when all colors come at once</line>
        <line>feel of disconnect with the ordinary world</line>
        <line>in a good way</line>
        <line>all melt away</line>
        <line>being washed</line>
        <line>pure and clean</line>
        <line>quality without compare</line>
      </stanza>
      <stanza>
        <line>water moving softly, extra quiet, please do not disturb!</line>
        <line>cloud figures floating above</line>
        <line>tree monsters arguing</line>
        <line>mountains move easily</line>
        <line>underwater beings looking up on us</line>
        <line>solar wind erupts and shoots emotional bursts of love and wordless connection</line>
      </stanza>
      <stanza>
        <line>eventually waking up to Earth again</line>
        <line>but,</line>
        <line>	something did change</line>
        <line>	something was born</line>
        <line>	and grew</line>
        <line>	keeps growing</line>
      </stanza>
      <stanza>
        <line>this special past &amp; present &amp; future day</line>
      </stanza>
    </poem>
    <poem name="resting" id="resting-086" seq="086" date="2015-08-10" time="19:31" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>time due for cracks to open</line>
        <line>eruption projects out into the wild</line>
        <line>without brakes or parachutes</line>
      </stanza>
      <stanza>
        <line>rest in that dreamy space</line>
        <line>her hair falling on my face, tickling</line>
        <line>breath</line>
        <line>filled with sparkle, oceans, mountains, dunes, dogs and cats, sandmen, empresses, wizards, myriad of celestial things</line>
      </stanza>
    </poem>
    <poem name="tender heart" id="tender-heart-087" seq="087" date="2015-08-10" time="22:55" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>very tender heart</line>
        <line>open and vulnerable</line>
        <line>but gives</line>
        <line>love and nourishment</line>
        <line>if handled carefully</line>
        <line>and put down nicely</line>
      </stanza>
    </poem>
    <poem name="hyper speed" id="hyper-speed-088" seq="088" date="2015-08-11" time="20:32" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>meanwhile…</line>
      </stanza>
      <stanza>
        <line>feel light tonight</line>
        <line>like it’s 7:77am not 7:77pm</line>
      </stanza>
      <stanza>
        <line>atmospheric turbulence vibe</line>
        <line caesura="3">as invisible supra/sonic/buzz/speed dragon vessel crafts</line>
        <line>settle moon dust</line>
      </stanza>
      <stanza>
        <line>uncovering…</line>
      </stanza>
      <stanza>
        <line>endearing and exhilarating and uniquely You and only!</line>
        <line>soft * sweet * raw * sexy * dreamy You and only!</line>
      </stanza>
      <stanza>
        <line>feel that trembling and adrenaline and heat</line>
        <line>tears… also warm serenity</line>
        <line>sensual eye ear touch body feeling</line>
        <line>beyond the ordinary</line>
      </stanza>
      <stanza>
        <line>like…</line>
      </stanza>
      <stanza>
        <line>star flakes falling</line>
        <line>as</line>
        <line>glistening ice on trees silver green reflects in your eyes</line>
        <line>walking a winter day</line>
        <line>hand in hand</line>
        <line>tightly silently connected</line>
        <line>by the magic inside the moment</line>
      </stanza>
      <stanza>
        <line>hyper pure…</line>
      </stanza>
    </poem>
    <poem name="spark" id="spark-089" seq="089" date="2015-08-19" time="20:31" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>arrrgg</line>
        <line>drives me crazy…</line>
        <line>guessed who called now?</line>
      </stanza>
      <stanza>
        <line>she is so happy and we are laughing and joking, and she missed my</line>
        <line>‘being’</line>
        <line>just makes me happy to hear! regardless</line>
        <line>she is the one deepest in my heart, beyond rational arguments</line>
        <line>can’t help this, how destructive it might be or not be</line>
      </stanza>
      <stanza>
        <line>drives me crazy…</line>
      </stanza>
      <stanza>
        <line>kind of spark just comes into me, hearing her, can’t help it</line>
        <line>exactly why I never gave up,</line>
      </stanza>
      <stanza>
        <line>she is at the beach wearing the clothes I picked</line>
        <line>might sound silly. And also my favorite dress that she wanted to get rid of, but kept because I asked her.</line>
      </stanza>
      <stanza>
        <line>sorry, getting emotional, needed to get this call as a healing for me.</line>
      </stanza>
    </poem>
    <poem name="2014" id="2014-090" seq="090" date="2015-08-20" time="11:22" year="2015" index="" xml:space="preserve">
      <stanza>
        <line caesura="1">I think I learned that I really have the capacity to love, and be loved back/appreciated at various levels. That is the main thing.</line>
      </stanza>
    </poem>
    <poem name="coasters" id="coasters-091" seq="091" date="2015-08-20" time="21:21" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>heavy dark metal on (Foreigner by Pallbearer)</line>
        <line>can’t shake fall out this week yet</line>
        <line>hyper up - maybe too electronic?</line>
        <line>then down</line>
      </stanza>
      <stanza>
        <line>I know all the theories</line>
        <line>realization comes a bit delayed</line>
        <line>it will</line>
      </stanza>
      <stanza>
        <line>meanwhile,</line>
        <line>some suffering is unavoidable</line>
      </stanza>
      <stanza>
        <line>love is never forgotten</line>
        <line>learning is never forgotten</line>
        <line>life is ever changing</line>
      </stanza>
      <stanza>
        <line>there are other voices in the ether</line>
        <line>can’t hear them clearly yet</line>
        <line>each one unique</line>
      </stanza>
      <stanza>
        <line>(“There is no escape….You say yes to the sunlight and</line>
        <line>pure fantasies, so you have to say yes to the filth and</line>
        <line>the nausea. Everything is within you, gold and mud,</line>
        <line>happiness and pain, the laughter of childhood and the</line>
        <line>apprehension of death. Say yes to everything, shirk</line>
        <line>nothing.” — Hermann Hesse)</line>
      </stanza>
    </poem>
    <poem name="12 links" id="12-links-092" seq="092" date="2015-08-20" time="21:33" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>[Twelve links of interdependent origination]</line>
      </stanza>
      <stanza>
        <line>1. Dependent on ignorance mental formations…</line>
        <line>2. … arise.</line>
        <line>3. From mental formations, rebirth consciousness arises.</line>
        <line>4. Consciousness gives rise to mental and physical phenomena.</line>
        <line>5. From mental and physical phenomena (náma rúpa), the spheres of the six senses arise.</line>
        <line>6. From the spheres of the six senses, contact arises.</line>
        <line>7. Contact causes sensation.</line>
        <line>&lt;— snip —&gt;</line>
        <line>8. Sensation leads to craving.</line>
        <line>9. From craving, attachment results.</line>
        <line>10. Attachment produces becoming.</line>
        <line>11. From becoming birth arises.</line>
        <line>12. Finally, birth leads to decay, death, grief, lamentation, pain (dukkha), sorrow, despair.</line>
      </stanza>
      <stanza>
        <line>In this way the whole mass of suffering arises.</line>
      </stanza>
    </poem>
    <poem name="watcher in the dark" id="watcher-in-the-dark-093" seq="093" date="2015-08-20" time="21:48" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>he is watching me in the dark</line>
        <line>I see all the light exposing - stratosphere of lights</line>
        <line>but I don’t see deep in the dark yet</line>
      </stanza>
      <stanza>
        <line>where the calm is</line>
        <line>where the equanimity is</line>
      </stanza>
      <stanza>
        <line>driving in the fog</line>
        <line>ice formations</line>
        <line>slippery</line>
      </stanza>
      <stanza>
        <line>dark means creation without assistance</line>
        <line>dark means falling, but not lethal</line>
      </stanza>
      <stanza>
        <line>need to fall to get to the next level</line>
        <line>or the same level</line>
        <line>with another perspective</line>
        <line>of the dark,</line>
        <line>another preparation</line>
      </stanza>
      <stanza>
        <line>as we are spinning on ice,</line>
        <line>without releasing</line>
        <line>without realizing</line>
      </stanza>
      <stanza>
        <line>that ego brought from light to darkness is its annihilation</line>
      </stanza>
      <stanza>
        <line>the suffering is also the dissolving of ego, like cleaning a wound with alcohol</line>
      </stanza>
      <stanza>
        <line>endless waves sweep though mind</line>
        <line>calming as the wind disappears and the eternal flame is not real</line>
        <line>can’t be burned by unreal flames unless believed</line>
      </stanza>
      <stanza>
        <line>so the light from the flame flickers as the candle burns out as the darkness enters</line>
      </stanza>
      <stanza>
        <line>he sits there smiling, seeing the sunrise</line>
      </stanza>
    </poem>
    <poem name="SC Salvation Army" id="sc-salvation-army-094" seq="094" date="2015-08-20" time="22:10" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>store early evening</line>
        <line>by coincidence</line>
      </stanza>
      <stanza>
        <line>having fashion show</line>
        <line>laughing, this unique moment</line>
      </stanza>
      <stanza>
        <line>need to break into fitting room</line>
      </stanza>
      <stanza>
        <line>picking sharply the right clothes</line>
        <line>both of us</line>
      </stanza>
      <stanza>
        <line>later,</line>
        <line>my blanket outside the art museum</line>
        <line>sipping and relaxing</line>
        <line>sharing tiger cake</line>
        <line>in the darkening night</line>
      </stanza>
      <stanza>
        <line>good and bad days will come</line>
        <line>but some days are unexpected magic</line>
        <line>wish everyone can have one once</line>
      </stanza>
    </poem>
    <poem name="don’t escape" id="don-t-escape-095" seq="095" date="2015-08-20" time="22:51" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>don’t escape this time</line>
        <line>embrace the small death until it doesn’t exist</line>
        <line>you don’t know the real reasons, might never</line>
        <line>nothing could be different, even wishing so</line>
      </stanza>
      <stanza>
        <line>letting go is a slow process, not fast</line>
      </stanza>
      <stanza>
        <line>“In the millions of mini-decisions we make day by day and moment by moment, we are challenged each time either to let go or to re-solidify. To let go cleanly—without re-solidifying—we can practice what my teacher Chögyam Trungpa Rinpoche referred to as “disowning”:</line>
      </stanza>
      <stanza>
        <line>Even though the acceptance of what is happening may be confusing, just accept the given situation and do not try to make it something else; do not try to make it into an educational process at all. Just see it, perceive it, and then abandon it. If you experience something and then disown that experience, you provide a space between that knowledge and yourself, which permits it simply to take its course.”</line>
      </stanza>
      <stanza>
        <line caesura="4">(http://www.tricycle.com/dharma-talk/letting-go)</line>
      </stanza>
    </poem>
    <poem name="in the tree" id="in-the-tree-096" seq="096" date="2015-08-20" time="22:59" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>inside the tree</line>
        <line>we sit silent</line>
      </stanza>
      <stanza>
        <line>the massive Redwood</line>
        <line>dark and warm</line>
      </stanza>
      <stanza>
        <line>blanket on the ground</line>
        <line>feel the surface</line>
      </stanza>
      <stanza>
        <line>of ancient times</line>
      </stanza>
    </poem>
    <poem name="insanity edit1" id="insanity-edit1-097" seq="097" date="2015-08-20" time="23:16" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>the stone hills are breaking</line>
        <line>battle ground forming massive injections</line>
        <line>lethal blood screams</line>
        <line>hot vastness of fire and smoke</line>
        <line>burning metal through the atmosphere</line>
      </stanza>
      <stanza>
        <line>turbulence as death Bardo is entered</line>
        <line>mind passing ranks up to end game</line>
      </stanza>
      <stanza>
        <line>walls soft and bolted doors,</line>
        <line>hear screaming of boiling blood</line>
      </stanza>
      <stanza>
        <line>entrances of skulls and bones</line>
        <line>are encrypted reality waves</line>
        <line>occult voodoo Satan laughing at the spectacle</line>
        <line>white phosphor magnesium crosses</line>
      </stanza>
      <stanza>
        <line>lake water emptied backwards</line>
        <line>carnal grounds levitated</line>
        <line>empty streets wishing for life</line>
        <line>maximum radioactive creation of non-conscious sub human processing</line>
      </stanza>
      <stanza>
        <line>this massive entrance opening not helping this time</line>
        <line>caving in, black hallways find echoes of my past and future</line>
        <line>going in the direction of illusions</line>
      </stanza>
      <stanza>
        <line>determination and active destruction yield cause and effect</line>
      </stanza>
      <stanza>
        <line>BUT PERFECTION!</line>
      </stanza>
      <stanza>
        <line>in all this messy crude pile of debris</line>
      </stanza>
      <stanza>
        <line>perfection is always there</line>
        <line>compassion as well</line>
      </stanza>
      <stanza>
        <line>so the story of another day</line>
        <line>is created</line>
      </stanza>
      <stanza>
        <line>regardless</line>
        <line>if we want it or not</line>
      </stanza>
    </poem>
    <poem name="insanity edit Dean" id="insanity-edit-dean-097" seq="097" date="2015-08-21" time="23:16" year="2015" index="" xml:space="preserve">
      <stanza>
        <line>the stone hills are breaking</line>
        <line>battle ground incentive massive injections</line>
        <line>lethal blood screams</line>
        <line>hot vastness of fire and smoke</line>
        <line>burning metallic atmosphere</line>
      </stanza>
      <stanza>
        <line>turbulence as death Bardo is entered</line>
        <line>mind passing ranks up to end game</line>
      </stanza>
