<?xml version="1.0" encoding="UTF-8"?>
<poetry>
  <about name="lenin" date="2012-05-12" uri="tag:perbergman.com,2012-05-12:lenin">
  </about>
  <poems>
    <poem name="mouth" id="mouth" xml:space="preserve">
      <stanza>
        <line>all thinking created in the mouth</line>
        <line>where inner and outer meets</line>
        <line>where the vomit comes out</line>
        <line>and the air in</line>
      </stanza>
    </poem>
  </poems>
</poetry>
